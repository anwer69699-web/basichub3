--// ARBIX HUB RTX V1 - SMOOTH DELIVERY LANDING

if getgenv().ARBIX_RUNNING then
    if getgenv().ARBIX_STOP then getgenv().ARBIX_STOP() end
end
getgenv().ARBIX_RUNNING = true

local Players = game:GetService("Players")
local Workspace = game:GetService("Workspace")
local RunService = game:GetService("RunService")

local player = Players.LocalPlayer

-- CONFIG
local config = {
    horizontalSpeed = 26,
    verticalSpeed = 27,
    maxHeight = 16,
    stopDistance = 6,
    landingSpeed = 27,
    maxDistance = 400
}

-- VARIABLES
local char, hrp
local moving = false
local currentVelocity = Vector3.zero
local lastDir = Vector3.zero
local flyButton
local gui
local connection = nil

-- STOP FUNCTION
getgenv().ARBIX_STOP = function()
    moving = false
    if connection then connection:Disconnect() connection=nil end
    if hrp then hrp.AssemblyLinearVelocity = Vector3.zero end
    if gui then gui:Destroy() end
    getgenv().ARBIX_RUNNING = false
end

-- CHARACTER SETUP
local function SetupCharacter(c)
    char = c
    hrp = char:WaitForChild("HumanoidRootPart")
    moving = false
    if hrp then hrp.AssemblyLinearVelocity = Vector3.zero end
end
if player.Character then SetupCharacter(player.Character) end
player.CharacterAdded:Connect(SetupCharacter)

-- SMOOTHING
local function Smooth(current, target, alpha)
    return current:Lerp(target, math.clamp(alpha, 0, 1))
end
local function StabilizeDirection(dir)
    if lastDir.Magnitude == 0 then
        lastDir = dir
        return dir
    end
    lastDir = lastDir:Lerp(dir, 0.25)
    return lastDir
end

-- FIND DELIVERY
local function FindTarget()
    local plots = Workspace:FindFirstChild("Plots")
    if not plots then return nil end
    for _, plot in pairs(plots:GetChildren()) do
        local sign = plot:FindFirstChild("PlotSign")
        if sign then
            local yourBase = sign:FindFirstChild("YourBase")
            if yourBase and yourBase.Enabled then
                return plot:FindFirstChild("DeliveryHitbox")
            end
        end
    end
    return nil
end

-- NORMAL FLIGHT MOVE WITH SMOOTH LANDING
local function MoveToTarget(target)
    if not hrp or not target then return end
    moving = true
    if flyButton then
        flyButton.Text = "⏹️ STOP"
        flyButton.BackgroundColor3 = Color3.fromRGB(255,50,50)
    end

    local startPos = hrp.Position
    local endPos = target.Position
    local traveled = 0

    connection = RunService.Heartbeat:Connect(function(dt)
        if not moving or not hrp or not target.Parent then
            if connection then connection:Disconnect() connection=nil end
            hrp.AssemblyLinearVelocity = Vector3.zero
            moving = false
            if flyButton then
                flyButton.Text = "✈️ NORMAL FLIGHT"
                flyButton.BackgroundColor3 = Color3.fromRGB(0,120,255)
            end
            return
        end

        local pos = hrp.Position
        local remainingDistance = (endPos - pos).Magnitude

        -- هبوط تدريجي عند الاقتراب من DeliveryBox
        if remainingDistance <= config.stopDistance + 2 then
            local landingDir = Vector3.new(0, -config.landingSpeed, 0)
            hrp.AssemblyLinearVelocity = landingDir
            if remainingDistance <= 0.5 then
                hrp.CFrame = CFrame.new(Vector3.new(endPos.X, endPos.Y, endPos.Z))
                hrp.AssemblyLinearVelocity = Vector3.zero
                moving = false
                if flyButton then
                    flyButton.Text = "✈️ NORMAL FLIGHT"
                    flyButton.BackgroundColor3 = Color3.fromRGB(0,120,255)
                end
                if connection then connection:Disconnect() connection=nil end
            end
            return
        end

        -- حركة النقل العادي
        local dir = StabilizeDirection(endPos - pos)
        local horizontalDir = Vector3.new(dir.X,0,dir.Z)
        local horizontal = horizontalDir.Magnitude > 0.1 and horizontalDir.Unit * config.horizontalSpeed or Vector3.zero

        traveled = traveled + horizontal.Magnitude * dt
        local progress = math.clamp(traveled / (endPos - startPos).Magnitude, 0, 1)
        local arcHeight = math.sin(progress * math.pi) * config.maxHeight
        local targetY = startPos.Y + (endPos.Y - startPos.Y) * progress + arcHeight
        local vertical = math.clamp((targetY - pos.Y)/math.max(dt,0.001), -config.verticalSpeed, config.verticalSpeed)

        currentVelocity = Smooth(currentVelocity, Vector3.new(horizontal.X, vertical, horizontal.Z), math.clamp(dt*6,0,1))
        hrp.AssemblyLinearVelocity = currentVelocity
    end)
end

-- GUI
local function MakeDraggable(frame)
    local dragging, dragInput, dragStart, startPos
    frame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            dragStart = input.Position
            startPos = frame.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then dragging = false end
            end)
        end
    end)
    frame.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement then dragInput = input end
    end)
    RunService.RenderStepped:Connect(function()
        if dragging and dragInput then
            local delta = dragInput.Position - dragStart
            frame.Position = UDim2.new(
                startPos.X.Scale, startPos.X.Offset + delta.X,
                startPos.Y.Scale, startPos.Y.Offset + delta.Y
            )
        end
    end)
end

-- CREATE GUI
local function CreateMainGUI()
    gui = Instance.new("ScreenGui")
    gui.Name = "ARBIX_HUB_GUI"
    gui.ResetOnSpawn = false
    gui.Parent = player.PlayerGui

    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(0,300,0,180)
    frame.Position = UDim2.new(0.5,-150,0.5,-90)
    frame.BackgroundColor3 = Color3.fromRGB(20,20,30)
    frame.Active = true
    frame.Parent = gui
    Instance.new("UICorner",frame).CornerRadius = UDim.new(0,8)
    MakeDraggable(frame)

    -- RAINBOW TITLE
    local title = Instance.new("TextLabel")
    title.Size = UDim2.new(1,0,0,40)
    title.Position = UDim2.new(0,0,0,5)
    title.BackgroundTransparency = 1
    title.Text = "ARBIX HUB RTX V1"
    title.Font = Enum.Font.GothamBold
    title.TextSize = 22
    title.TextColor3 = Color3.fromRGB(255,0,0)
    title.Parent = frame

    -- MADE BY SPARKLINEDEV
    local subtitle = Instance.new("TextLabel")
    subtitle.Size = UDim2.new(1,0,0,20)
    subtitle.Position = UDim2.new(0,0,0,50)
    subtitle.BackgroundTransparency = 1
    subtitle.Text = "Made by sparklinedev"
    subtitle.Font = Enum.Font.Gotham
    subtitle.TextSize = 14
    subtitle.TextColor3 = Color3.fromRGB(180,180,180)
    subtitle.Parent = frame

    -- FLY BUTTON
    flyButton = Instance.new("TextButton")
    flyButton.Size = UDim2.new(0.8,0,0,35)
    flyButton.Position = UDim2.new(0.1,0,0.7,0)
    flyButton.Text = "Fly to Delivery"
    flyButton.Font = Enum.Font.GothamBold
    flyButton.TextSize = 16
    flyButton.BackgroundColor3 = Color3.fromRGB(0,120,255)
    flyButton.TextColor3 = Color3.new(1,1,1)
    flyButton.Parent = frame
    Instance.new("UICorner",flyButton)

    flyButton.MouseButton1Click:Connect(function()
        if moving then moving = false return end
        local target = FindTarget()
        if target then
            MoveToTarget(target)
        else
            flyButton.Text = "No Delivery Found"
            wait(2)
            flyButton.Text = "Fly to Delivery"
        end
    end)
end

CreateMainGUI()
