local function startSpeedBoost()
    if Connections.speed then return end
    
    Connections.speed = RunService.Heartbeat:Connect(function()
        if not Enabled.SpeedBoost and not Enabled.AutoLeft and not Enabled.AutoRight then 
            return 
        end
        
        pcall(function()
            local c = Player.Character
            if not c then return end
            local h = c:FindFirstChild("HumanoidRootPart")
            local hum = c:FindFirstChildOfClass("Humanoid")
            if not h or not hum then return end
            
            if Enabled.AutoLeft or Enabled.AutoRight then
                return
            end
            
            if Enabled.SpeedBoost then
                local md = hum.MoveDirection
                if md.Magnitude > 0.1 then
                    local isStealing = Player:GetAttribute("Stealing")
                    local currentSpeed = isStealing and Values.STEAL_SPEED or Values.NORMAL_SPEED
                    
                    local jitter = Vector3.new(
                        math.random(-Values.JITTER_AMOUNT, Values.JITTER_AMOUNT),
                        0,
                        math.random(-Values.JITTER_AMOUNT, Values.JITTER_AMOUNT)
                    ) * 0.5
                    
                    h.AssemblyLinearVelocity = Vector3.new(
                        md.X * currentSpeed + jitter.X, 
                        h.AssemblyLinearVelocity.Y, 
                        md.Z * currentSpeed + jitter.Z
                    )
                end
            end
        end)
    end)
end

local function stopSpeedBoost()
    if Connections.speed then 
        Connections.speed:Disconnect() 
        Connections.speed = nil 
    end
end

--// ==================== [5] Auto Walk System ====================

local function startMovementSystem()
    if getgenv().MovementLoop then
        pcall(function() getgenv().MovementLoop:Disconnect() end)
    end
    
    getgenv().MovementLoop = RunService.Heartbeat:Connect(function()
        if not Enabled.AutoLeft and not Enabled.AutoRight then
            return
        end
        
        pcall(function()
            local c = Player.Character
            if not c then return end
            local h = c:FindFirstChild("HumanoidRootPart")
            local hum = c:FindFirstChildOfClass("Humanoid")
            if not h or not hum then return end
            
            local points = nil
            if Enabled.AutoLeft then
                points = LEFT_POINTS
                currentPath = "LEFT"
            elseif Enabled.AutoRight then
                points = RIGHT_POINTS
                currentPath = "RIGHT"
            end
            
            if not points then return end
            
            if waitingForSteal then
                if Player:GetAttribute("Stealing") then
                    waitingForSteal = false
                    autoPhase = "POINT_3"
                else
                    hum:Move(Vector3.zero, false)
                    h.AssemblyLinearVelocity = Vector3.new(0, h.AssemblyLinearVelocity.Y, 0)
                    return
                end
            end
            
            local currentPoint = points[autoPhase]
            if not currentPoint then
                if autoPhase == "END" then
                    autoPhase = "START"
                    currentPoint = points.START
                    print("LOOP: Restarting")
                else
                    autoPhase = "START"
                    currentPoint = points.START
                end
            end
            
            local targetPos = Vector3.new(currentPoint.X, h.Position.Y, currentPoint.Z)
            local dist = (targetPos - h.Position).Magnitude
            
            if dist < 1.5 then
                if autoPhase == "START" then
                    autoPhase = "POINT_2"
                elseif autoPhase == "POINT_2" then
                    waitingForSteal = true
                    hum:Move(Vector3.zero, false)
                    return
                elseif autoPhase == "POINT_3" then
                    autoPhase = "END"
                elseif autoPhase == "END" then
                    autoPhase = "START"
                    print("LOOP: Reached END")
                    return
                end
            end
            
            local isStealing = Player:GetAttribute("Stealing")
            local speed = isStealing and Values.STEAL_SPEED or Values.AUTO_SPEED
            
            if speed < Values.MAX_SPEED and not isStealing then
                speed = Values.MAX_SPEED
            end
            
            local dir = (targetPos - h.Position).Unit
            dir = Vector3.new(dir.X, 0, dir.Z).Unit
            
            local jitter = Vector3.new(
                math.random(-Values.JITTER_AMOUNT, Values.JITTER_AMOUNT),
                0,
                math.random(-Values.JITTER_AMOUNT, Values.JITTER_AMOUNT)
            ) * 0.3
            
            local velocity = dir * speed
            h.AssemblyLinearVelocity = Vector3.new(
                velocity.X + jitter.X,
                h.AssemblyLinearVelocity.Y,
                velocity.Z + jitter.Z
            )
            
            hum:Move(dir, false)
        end)
    end)
end

local function stopMovementSystem()
    if getgenv().MovementLoop then
        pcall(function() getgenv().MovementLoop:Disconnect() end)
        getgenv().MovementLoop = nil
    end
    
    autoPhase = "START"
    waitingForSteal = false
    currentPath = nil
    
    pcall(function()
        local c = Player.Character
        if c then
            local hum = c:FindFirstChildOfClass("Humanoid")
            if hum then 
                hum:Move(Vector3.zero, false) 
            end
        end
    end)
end

