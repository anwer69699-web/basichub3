-- الدالة الرئيسية للـ Desync الذكي
local function UpdateDesync()
    local char = LocalPlayer.Character
    if not char then return end
    
    local hrp = char:FindFirstChild("HumanoidRootPart")
    local humanoid = char:FindFirstChildOfClass("Humanoid")
    if not hrp or not humanoid then return end
    
    local realPos = hrp.Position
    local currentSpeed = IsStealing and STEAL_SPEED or NORMAL_SPEED
    
    -- === المنطق الذكي للموقع الزائف ===
    
    -- 1. إذا كان الموقع الزائف فارغ، ابدأ من الموقع الحقيقي
    if not FakePosition then
        FakePosition = realPos
    end
    
    -- 2. احسب المسافة بين الموقع الحقيقي والزائف
    local distance = (realPos - FakePosition).Magnitude
    
    -- 3. إذا تجاوزت المسافة UPDATE_DISTANCE، حرك الموقع الزائف تدريجياً
    if distance > UPDATE_DISTANCE then
        -- اتجاه الحركة من الموقع الزائف نحو الحقيقي
        local direction = (realPos - FakePosition).Unit
        -- حرك الموقع الزائف باتجاه الحقيقي بسرعة INTERPOLATION_SPEED
        FakePosition = FakePosition + (direction * INTERPOLATION_SPEED * 0.1)
        
        -- تأكد إنه ما زال أبعد من UPDATE_DISTANCE شوي
        if (realPos - FakePosition).Magnitude < UPDATE_DISTANCE - 2 then
            FakePosition = realPos - (direction * (UPDATE_DISTANCE - 2))
        end
    else
        -- 4. إذا المسافة مناسبة، حافظ على الموقع الزائف ثابت نسبياً
        -- (لا تتحرك مع اللاعب، خليه ثابت عشان الـ Desync يشتغل)
        
        -- بس حركه شوي عشان ما يكون ثابت تماماً (يخلي السيرفر يشك أقل)
        local randomOffset = Vector3.new(
            math.sin(tick() * 0.5) * 0.1,
            0,
            math.cos(tick() * 0.5) * 0.1
        )
        FakePosition = FakePosition + randomOffset
    end
    
    -- 5. إرسال الموقع الزائف للسيرفر (بمعدل محدود)
    local now = tick()
    if now - LastUpdateTime >= UpdateInterval then
        LastUpdateTime = now
        SendPosition(FakePosition)
    end
    
    -- 6. تطبيق السرعة على اللاعب
    humanoid.WalkSpeed = currentSpeed > 32 and 32 or currentSpeed
    
    -- إذا السرعة أعلى من 32، استخدم AssemblyLinearVelocity
    if currentSpeed > 32 and humanoid.MoveDirection.Magnitude > 0.1 then
        local velocity = hrp.AssemblyLinearVelocity
        local targetVel = humanoid.MoveDirection * currentSpeed
        hrp.AssemblyLinearVelocity = Vector3.new(
            velocity.X + (targetVel.X - velocity.X) * 0.15,
            velocity.Y,
            velocity.Z + (targetVel.Z - velocity.Z) * 0.15
        )
    end
    
    -- 7. تحديث الواجهة
    if tick() % 0.3 < 0.05 then
        ServerPosition = GetServerPosition()
        local distText = math.floor(distance)
        local serverDist = ServerPosition and math.floor((ServerPosition - FakePosition).Magnitude) or 0
        
        DistanceLabel.Text = "المسافة: " .. distText .. "m | سيرفر: " .. serverDist .. "m"
        
        if ServerPosition and serverDist < 8 then
            StatusLabel.Text = "متزامن (" .. serverDist .. "m)"
            StatusLabel.TextColor3 = Color3.fromRGB(100, 255, 100)
        else
            StatusLabel.Text = "Desync نشط (" .. distText .. "m)"
            StatusLabel.TextColor3 = Color3.fromRGB(255, 200, 100)
        end
    end
end

-- تفعيل/إيقاف Desync
local function ToggleDesync()
    DesyncEnabled = not DesyncEnabled
    
    if DesyncEnabled then
        -- تهيئة الموقع الزائف
        local char = LocalPlayer.Character
        if char then
            local hrp = char:FindFirstChild("HumanoidRootPart")
            if hrp then
                FakePosition = hrp.Position
            end
        end
        
        SetDesync(true)
        FastRespawn()
        
        -- بدء الـ Loop
        Connection_RenderStepped = RunService.Heartbeat:Connect(UpdateDesync)
        
        TweenService:Create(ToggleBtn, TweenInfo.new(0.3), {
            BackgroundColor3 = Color3.fromRGB(0, 170, 127), 
            TextColor3 = Color3.fromRGB(255, 255, 255)
        }):Play()
        ToggleBtn.Text = "Desync: مفعل"
        
        Notify("FR HUB", "Desync V11 نشط! الموقع يتحرك ذكياً", 3)
    else
        -- إيقاف
        if Connection_RenderStepped then
            Connection_RenderStepped:Disconnect()
            Connection_RenderStepped = nil
        end
        
        SetDesync(false)
        FakePosition = nil
        
        -- إعادة السرعة الطبيعية
        local char = LocalPlayer.Character
        if char then
            local humanoid = char:FindFirstChildOfClass("Humanoid")
            if humanoid then humanoid.WalkSpeed = 16 end
        end
        
        TweenService:Create(ToggleBtn, TweenInfo.new(0.3), {
            BackgroundColor3 = Color3.fromRGB(45, 45, 45), 
            TextColor3 = Color3.fromRGB(200, 200, 200)
        }):Play()
        ToggleBtn.Text = "تفعيل Desync"
        StatusLabel.Text = "الحالة: متوقف"
        StatusLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
        DistanceLabel.Text = "المسافة: 0m | تجديد عند: " .. UPDATE_DISTANCE .. "m"
        
        Notify("FR HUB", "تم إيقاف Desync", 2)
    end
end

