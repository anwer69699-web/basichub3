-- =========================
-- 🔒 LOCK & MOVE
-- =========================
local oldWalk, oldJump = humanoid.WalkSpeed, humanoid.JumpPower
local controlling = false

local function Lock(state)
    humanoid.WalkSpeed = state and 0 or oldWalk
    humanoid.JumpPower = state and 0 or oldJump
end

local function Stop()
    controlling = false
    hrp.AssemblyLinearVelocity = Vector3.zero
    Lock(false)
end

local function MoveLift(pos, speed)
    controlling = true
    Lock(true)
    local target = Vector3.new(pos.X, pos.Y + getgenv().Config.LiftHeight, pos.Z)
    local dir = target - hrp.Position
    local flat = Vector3.new(dir.X,0,dir.Z)
    local vel = flat.Magnitude > 2 and flat.Unit * speed or Vector3.zero
    vel += Vector3.new(0,(target.Y-hrp.Position.Y)*2,0)
    hrp.AssemblyLinearVelocity = vel
end

local function MoveFlat(pos, speed)
    controlling = true
    local dir = pos - hrp.Position
    local flat = Vector3.new(dir.X,0,dir.Z)
    hrp.AssemblyLinearVelocity = flat.Magnitude > 2 and flat.Unit * speed or Vector3.zero
end

-- =========================
-- 🔍 DELIVERY
-- =========================
local function IsMine(plot)
    local s = plot:FindFirstChild("PlotSign")
    return s and s:FindFirstChild("YourBase") and s.YourBase.Enabled
end

local function GetMyDelivery()
    local plots = workspace:FindFirstChild("Plots")
    if not plots then return end
    for _,p in pairs(plots:GetChildren()) do
        if IsMine(p) then
            for _,v in pairs(p:GetDescendants()) do
                if v.Name:lower():find("delivery") then return v end
            end
        end
    end
end

local function GetOtherDelivery()
    local plots = workspace:FindFirstChild("Plots")
    if not plots then return end
    local best,dist=nil,math.huge
    for _,p in pairs(plots:GetChildren()) do
        if not IsMine(p) then
            for _,v in pairs(p:GetDescendants()) do
                if v.Name:lower():find("delivery") then
                    local d=(hrp.Position-v.Position).Magnitude
                    if d<dist then dist=d; best=v end
                end
            end
        end
    end
    return best
end

-- =========================
-- 🔁 LOOP
-- =========================
task.spawn(function()
    while true do
        local active=false
        if getgenv().States.AutoDelivery then
            local t=GetMyDelivery()
            if t then MoveLift(t.Position,getgenv().Config.Speed.AutoDelivery) active=true end
        elseif getgenv().States.OtherDeliveryMove then
            local t=GetOtherDelivery()
            if t then MoveFlat(t.Position,getgenv().Config.Speed.OtherDelivery) active=true end
        elseif getgenv().States.FollowPlayer then
            local closest,dist=nil,math.huge
            for _,p in pairs(Players:GetPlayers()) do
                if p~=player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                    local d=(hrp.Position-p.Character.HumanoidRootPart.Position).Magnitude
                    if d<dist then dist=d; closest=p.Character.HumanoidRootPart end
                end
            end
            if closest then MoveFlat(closest.Position,getgenv().Config.Speed.FollowPlayer) active=true end
        end
        if not active and controlling then Stop() end
        task.wait(0.08)
    end
end)

