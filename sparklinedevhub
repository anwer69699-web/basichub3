local function OnCharacterAdded(newChar)
    if not DesyncEnabled then return end
    local hrp = newChar:WaitForChild("HumanoidRootPart", 2)
    if not hrp then return end
    
    SetDesync(true)
    
    -- إرسال بمعدل أقل (0.08 ثانية)
    task.spawn(function()
        while DesyncEnabled and newChar.Parent do
            if TargetServerPosition then
                SendFakePosition(TargetServerPosition)
            end
            task.wait(SendInterval)
        end
    end)
end

local function ToggleDesync()
    DesyncEnabled = not DesyncEnabled
    if DesyncEnabled then
        StartRB()
        TweenService:Create(ToggleBtn, TweenInfo.new(0.3), {BackgroundColor3 = Color3.fromRGB(0, 170, 127), TextColor3 = Color3.fromRGB(255, 255, 255)}):Play()
        ToggleBtn.Text = "Desync: مفعل"
        StatusLabel.Text = "جاري المحاولة..."
        StatusLabel.TextColor3 = Color3.fromRGB(255, 255, 100)
        
        local char = LocalPlayer.Character
        local hrp = char and char:FindFirstChild("HumanoidRootPart")
        if hrp then
            TargetServerPosition = hrp.Position
        end
        
        SetDesync(true)
        FastRespawn()
        Notify("FR HUB", "تم تفعيل الDesync المحسّن!", 2)
        
        if not FakePosHighlight or not FakePosHighlight.Parent then
            CreateHighlight()
        end
        
        if TargetServerPosition and ServerPosPart then
            ServerPosPart.CFrame = CFrame.new(TargetServerPosition)
            ServerPosPart.Transparency = 1
            FakePosHighlight.CFrame = CFrame.new(TargetServerPosition)
            FakePosHighlight.Visible = false
            FakePosLabel.Adornee = ServerPosPart
            FakePosLabel.Enabled = false
        end
        
        -- Loop رئيسي بمعدل أقل (0.08 ثانية)
        Connection_RenderStepped = RunService.Heartbeat:Connect(function()
            local char = LocalPlayer.Character
            local hrp = char and char:FindFirstChild("HumanoidRootPart")
            
            if hrp and TargetServerPosition then
                -- إرسال الموقع بمعدل محدود
                SendFakePosition(TargetServerPosition)
                
                -- تحديث العرض بمعدل أقل (كل 0.2 ثانية)
                if tick() % 0.2 < 0.05 then
                    ActualServerPosition = GetActualServerPosition()
                    local realPos = hrp.Position
                    local distance = (realPos - TargetServerPosition).Magnitude
                    
                    if ActualServerPosition then
                        local actualDistance = (ActualServerPosition - TargetServerPosition).Magnitude
                        RealPosLabel.Text = "السيرفر " .. math.floor(ActualServerPosition.X) .. ", " .. math.floor(ActualServerPosition.Z) ..
                                           "\nالفرق: " .. math.floor(actualDistance) .. "m"
                        
                        if actualDistance < 5 then
                            StatusLabel.Text = "ناجح! (" .. math.floor(actualDistance) .. "m)"
                            StatusLabel.TextColor3 = Color3.fromRGB(0, 255, 100)
                            FakePosHighlight.Color3 = Color3.fromRGB(0, 255, 0)
                        else
                            StatusLabel.Text = "فشل! (" .. math.floor(actualDistance) .. "m)"
                            StatusLabel.TextColor3 = Color3.fromRGB(255, 50, 50)
                            FakePosHighlight.Color3 = Color3.fromRGB(255, 0, 0)
                        end
                    else
                        if distance > 10 then
                            StatusLabel.Text = "شغال (" .. math.floor(distance) .. "m)"
                            StatusLabel.TextColor3 = Color3.fromRGB(100, 255, 100)
                        else
                            StatusLabel.Text = "شغال (" .. math.floor(distance) .. "m)"
                            StatusLabel.TextColor3 = Color3.fromRGB(255, 200, 0)
                        end
                    end
                end
            end
        end)
        
        CharacterAddedConnection = LocalPlayer.CharacterAdded:Connect(OnCharacterAdded)
    else
        StopRB()
        TweenService:Create(ToggleBtn, TweenInfo.new(0.3), {BackgroundColor3 = Color3.fromRGB(45, 45, 45), TextColor3 = Color3.fromRGB(200, 200, 200)}):Play()
        ToggleBtn.Text = "تفعيل Desync"
        StatusLabel.Text = "الحالة: متوقف"
        StatusLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
        RealPosLabel.Text = "سرعة محسّنة - بدون لاق"
        SetDesync(false)
        if Connection_RenderStepped then Connection_RenderStepped:Disconnect() end
        if CharacterAddedConnection then CharacterAddedConnection:Disconnect() end
        if FakePosHighlight then 
            FakePosHighlight.Visible = false 
            FakePosHighlight.Color3 = Color3.fromRGB(255, 0, 0)
        end
        if FakePosLabel then 
            FakePosLabel.Enabled = false 
        end
        if ServerPosPart then ServerPosPart.Transparency = 1 end
        TargetServerPosition = nil
        ActualServerPosition = nil
        Notify("FR HUB", "تم إيقاف الDesync!", 2)
    end
end

