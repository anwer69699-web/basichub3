--// ==================== [3] Advanced Anti-Ragdoll System ====================

local AntiRagdollData = {
    IsRagdolled = false,
    LastRagdollTime = 0,
    RagdollConnection = nil,
    RecoveryConnection = nil,
    RagdollState = nil,
}

local function isActuallyRagdolled()
    local c = Player.Character
    if not c then return false end
    
    local hum = c:FindFirstChildOfClass("Humanoid")
    local hrp = c:FindFirstChild("HumanoidRootPart")
    if not hum or not hrp then return false end
    
    --// Check multiple ragdoll indicators
    local state = hum:GetState()
    local isRagdollState = (state == Enum.HumanoidStateType.Ragdoll or 
                           state == Enum.HumanoidStateType.FallingDown or
                           state == Enum.HumanoidStateType.Physics)
    
    local isPlatformStand = hum.PlatformStand == true
    local isAnchored = hrp.Anchored
    local highVelocity = hrp.AssemblyLinearVelocity.Magnitude > 100
    
    --// Check for ragdoll constraints (joints broken)
    local hasRagdollJoints = false
    for _, v in pairs(c:GetDescendants()) do
        if v:IsA("BallSocketConstraint") or v:IsA("HingeConstraint") then
            if v.Name:lower():find("ragdoll") or v.Name:lower():find("neck") then
                hasRagdollJoints = true
                break
            end
        end
    end
    
    return isRagdollState or isPlatformStand or hasRagdollJoints or (highVelocity and isAnchored)
end

local function forceUnragdoll()
    local c = Player.Character
    if not c then return end
    
    local hum = c:FindFirstChildOfClass("Humanoid")
    local hrp = c:FindFirstChild("HumanoidRootPart")
    if not hum or not hrp then return end
    
    --// Save current position
    local savedPos = hrp.Position
    local savedRot = hrp.CFrame.Rotation
    
    --// Kill all velocity instantly
    hrp.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
    hrp.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
    hrp.Velocity = Vector3.new(0, 0, 0)
    
    --// Break ragdoll joints
    for _, v in pairs(c:GetDescendants()) do
        if v:IsA("BallSocketConstraint") or v:IsA("HingeConstraint") or v:IsA("WeldConstraint") then
            if v.Name:lower():find("ragdoll") or v.Name:lower():find("neck") or v.Name:lower():find("joint") then
                pcall(function() v:Destroy() end)
            end
        end
    end
    
    --// Reset humanoid state
    pcall(function()
        hum.PlatformStand = false
        hum:ChangeState(Enum.HumanoidStateType.GettingUp)
        hum:ChangeState(Enum.HumanoidStateType.RunningNoPhysics)
        hum.AutoRotate = true
    end)
    
    --// Brief anchor to stabilize
    hrp.Anchored = true
    
    --// Restore position precisely
    hrp.CFrame = CFrame.new(savedPos) * savedRot
    
    --// Unanchor immediately with delay for physics sync
    task.delay(0.05, function()
        pcall(function()
            hrp.Anchored = false
            
            --// Ensure movement is free
            hum:Move(Vector3.zero, false)
            
            --// Small upward boost to prevent sticking
            hrp.AssemblyLinearVelocity = Vector3.new(0, 5, 0)
        end)
    end)
    
    --// Full recovery after unanchor
    task.delay(0.1, function()
        pcall(function()
            hum:ChangeState(Enum.HumanoidStateType.Running)
            hum.WalkSpeed = hum.WalkSpeed -- Refresh walk speed
        end)
    end)
end

local function startAntiRagdollSystem()
    if AntiRagdollData.RagdollConnection then return end
    
    print("Anti-Ragdoll System STARTED - Advanced Version")
    
    AntiRagdollData.RagdollConnection = RunService.Heartbeat:Connect(function()
        if not Enabled.AntiRagdoll then return end
        
        local currentlyRagdolled = isActuallyRagdolled()
        
        if currentlyRagdolled and not AntiRagdollData.IsRagdolled then
            --// Just entered ragdoll
            AntiRagdollData.IsRagdolled = true
            AntiRagdollData.LastRagdollTime = tick()
            forceUnragdoll()
            
        elseif currentlyRagdolled and AntiRagdollData.IsRagdolled then
            --// Still ragdoll - force unragdoll again if needed
            local timeInRagdoll = tick() - AntiRagdollData.LastRagdollTime
            if timeInRagdoll > 0.1 then
                forceUnragdoll()
                AntiRagdollData.LastRagdollTime = tick()
            end
            
        elseif not currentlyRagdolled and AntiRagdollData.IsRagdolled then
            --// Exited ragdoll naturally
            AntiRagdollData.IsRagdolled = false
            
            --// Ensure full movement capability
            pcall(function()
                local c = Player.Character
                if c then
                    local hum = c:FindFirstChildOfClass("Humanoid")
                    if hum then
                        hum:ChangeState(Enum.HumanoidStateType.Running)
                        hum.PlatformStand = false
                    end
                end
            end)
        end
    end)
end

local function stopAntiRagdollSystem()
    if AntiRagdollData.RagdollConnection then
        AntiRagdollData.RagdollConnection:Disconnect()
        AntiRagdollData.RagdollConnection = nil
    end
    AntiRagdollData.IsRagdolled = false
    print("Anti-Ragdoll System STOPPED")
end

