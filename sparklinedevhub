-- الدالة الرئيسية - نفس النظام الأصلي
local function UpdateDesync()
    local char = LocalPlayer.Character
    if not char then return end
    
    local hrp = char:FindFirstChild("HumanoidRootPart")
    local humanoid = char:FindFirstChildOfClass("Humanoid")
    if not hrp or not humanoid then return end
    
    local realPos = hrp.Position
    local currentSpeed = IsStealing and STEAL_SPEED or NORMAL_SPEED
    
    -- إعداد الموقع الزائف أول مرة
    if not FakePosition then
        FakePosition = realPos
    end
    
    -- حساب المسافة
    local distance = (realPos - FakePosition).Magnitude
    
    -- تحديث الموقع الزائف فقط عند الابتعاد
    if distance > UPDATE_DISTANCE then
        -- تحريك تدريجي نحو اللاعب
        local direction = (realPos - FakePosition).Unit
        FakePosition = FakePosition + (direction * 5)
        
        -- الحفاظ على المسافة
        if (realPos - FakePosition).Magnitude < UPDATE_DISTANCE - 3 then
            FakePosition = realPos - (direction * (UPDATE_DISTANCE - 3))
        end
    end
    
    -- إرسال الموقع الزائف
    SendFakePosition(FakePosition)
    
    -- تطبيق السرعة
    humanoid.WalkSpeed = currentSpeed
    
    -- تحديث الواجهة
    if tick() % 0.3 < 0.05 then
        local serverPos = GetServerPosition()
        local serverDist = serverPos and math.floor((serverPos - FakePosition).Magnitude) or 0
        DistanceLabel.Text = "مسافة: " .. math.floor(distance) .. "m | سيرفر: " .. serverDist .. "m"
        
        if serverDist < 10 then
            StatusLabel.Text = "متزامن (" .. serverDist .. "m)"
            StatusLabel.TextColor3 = Color3.fromRGB(100, 255, 100)
        else
            StatusLabel.Text = "Desync نشط"
            StatusLabel.TextColor3 = Color3.fromRGB(255, 200, 100)
        end
    end
end

local function ToggleDesync()
    DesyncEnabled = not DesyncEnabled
    
    if DesyncEnabled then
        local char = LocalPlayer.Character
        if char then
            local hrp = char:FindFirstChild("HumanoidRootPart")
            if hrp then FakePosition = hrp.Position end
        end
        
        SetDesync(true)
        FastRespawn()
        
        Connection_RenderStepped = RunService.Heartbeat:Connect(UpdateDesync)
        
        TweenService:Create(ToggleBtn, TweenInfo.new(0.3), {BackgroundColor3 = Color3.fromRGB(0, 170, 127)}):Play()
        ToggleBtn.Text = "Desync: مفعل"
        Notify("FR HUB", "Desync V12 نشط!", 3)
    else
        if Connection_RenderStepped then
            Connection_RenderStepped:Disconnect()
            Connection_RenderStepped = nil
        end
        
        SetDesync(false)
        FakePosition = nil
        
        local char = LocalPlayer.Character
        if char then
            local humanoid = char:FindFirstChildOfClass("Humanoid")
            if humanoid then humanoid.WalkSpeed = 16 end
        end
        
        TweenService:Create(ToggleBtn, TweenInfo.new(0.3), {BackgroundColor3 = Color3.fromRGB(45, 45, 45)}):Play()
        ToggleBtn.Text = "تفعيل Desync"
        StatusLabel.Text = "الحالة: متوقف"
        StatusLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
        
        Notify("FR HUB", "تم الإيقاف", 2)
    end
end

