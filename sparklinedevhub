-- نظام السحب
local dragging, dragInput, dragStart, startPos
local function update(input)
    local delta = input.Position - dragStart
    MainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
end

Header.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = MainFrame.Position
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then dragging = false end
        end)
    end
end)

Header.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
        dragInput = input
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if input == dragInput and dragging then update(input) end
end)

-- متغيرات النظام
local SpeedEnabled = false
local IsSprinting = false
local IsStealing = false
local CurrentSpeed = Settings.WalkSpeed
local VelocityConnection = nil
local NetworkConnection = nil
local LastSentPosition = nil
local LastSentTime = 0

-- دالة آمنة لتغيير السرعة باستخدام AssemblyLinearVelocity
local function ApplySmoothSpeed(targetSpeed)
    local char = LocalPlayer.Character
    if not char then return end
    
    local hrp = char:FindFirstChild("HumanoidRootPart")
    local humanoid = char:FindFirstChildOfClass("Humanoid")
    if not hrp or not humanoid then return end
    
    -- استخدام WalkSpeed الأساسي كأساس
    humanoid.WalkSpeed = math.min(targetSpeed, 32) -- الحد الأقصى لـ WalkSpeed الآمن
    
    -- إذا أردنا سرعة أعلى، نستخدم AssemblyLinearVelocity بشكل ذكي
    if targetSpeed > 32 and Settings.UseAssemblyVelocity then
        local currentVelocity = hrp.AssemblyLinearVelocity
        local moveDirection = humanoid.MoveDirection
        
        if moveDirection.Magnitude > 0.1 then
            -- حساب السرعة المستهدفة مع تسارع سلس
            local targetVelocity = moveDirection * targetSpeed
            local smoothVelocity = currentVelocity:Lerp(targetVelocity, 0.3) -- تسارع سلس
            
            -- تطبيق فقط على المحاور الأفقية، الحفاظ على الجاذبية
            hrp.AssemblyLinearVelocity = Vector3.new(
                smoothVelocity.X,
                currentVelocity.Y, -- الحفاظ على سرعة السقوط/القفز الطبيعية
                smoothVelocity.Z
            )
        end
    end
end

-- نظام Client Prediction (التنبؤ)
local function UpdateWithPrediction()
    if not SpeedEnabled then return end
    
    local char = LocalPlayer.Character
    if not char then return end
    
    local hrp = char:FindFirstChild("HumanoidRootPart")
    local humanoid = char:FindFirstChildOfClass("Humanoid")
    if not hrp or not humanoid then return end
    
    -- تحديد السرعة الحالية
    local targetSpeed = CurrentSpeed
    if IsStealing then
        targetSpeed = Settings.StealSpeed
    elseif IsSprinting then
        targetSpeed = Settings.SprintSpeed
    end
    
    -- تطبيق السرعة بشكل سلس
    ApplySmoothSpeed(targetSpeed)
    
    -- Client Prediction: التنبؤ بالموقع المستقبلي
    if Settings.PredictionEnabled then
        local velocity = hrp.AssemblyLinearVelocity
        local predictedPosition = hrp.Position + (velocity * 0.05) -- التنبؤ بـ 50ms قادمة
        
        -- إرسال التنبؤ للسيرفر بدلاً من الموقع الحالي (يقلل الـ Latency)
        -- هذا يتم تلقائياً من خلال Roblox physics replication
    end
end

-- نظام تحديث الشبكة المحسّن (قليل التحديثات)
local function OptimizedNetworkUpdate()
    if not SpeedEnabled then return end
    
    local char = LocalPlayer.Character
    if not char then return end
    
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    
    local currentTime = tick()
    
    -- إرسال تحديث فقط إذا:
    -- 1. مر وقت كافٍ منذ آخر تحديث
    -- 2. تغير الموقع بشكل ملحوظ
    -- 3. تغيرت السرعة بشكل كبير
    
    local shouldUpdate = false
    
    if currentTime - LastSentTime >= Settings.NetworkUpdateRate then
        shouldUpdate = true
    end
    
    if LastSentPosition then
        local distance = (hrp.Position - LastSentPosition).Magnitude
        if distance > 5 then -- تحديث فقط إذا تحركنا أكثر من 5 متر
            shouldUpdate = true
        end
    else
        shouldUpdate = true
    end
    
    if shouldUpdate then
        LastSentPosition = hrp.Position
        LastSentTime = currentTime
        
        -- لا نرسل بيانات يدوياً - نترك Roblox يتولى الـ replication
        -- هذا يمنع الـ Overload ويحافظ على التزامن
    end
end

-- دالة التفعيل/الإيقاف
local function ToggleSpeed()
    SpeedEnabled = not SpeedEnabled
    
    if SpeedEnabled then
        -- بدء النظام
        VelocityConnection = RunService.Heartbeat:Connect(function()
            UpdateWithPrediction()
            OptimizedNetworkUpdate()
        end)
        
        Notify("FR HUB", "تم تفعيل السرعة السلسة!", 2)
    else
        -- إيقاف النظام
        if VelocityConnection then
            VelocityConnection:Disconnect()
            VelocityConnection = nil
        end
        
        -- إعادة السرعة الطبيعية
        local char = LocalPlayer.Character
        if char then
            local humanoid = char:FindFirstChildOfClass("Humanoid")
            if humanoid then
                humanoid.WalkSpeed = 16 -- السرعة الافتراضية
            end
        end
        
        Notify("FR HUB", "تم إيقاف السرعة", 2)
    end
    
    return SpeedEnabled
end

