-- FR Desync + Insta Steal Auto - سرعة سرقة 15

local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local RunService = game:GetService("RunService")
local StarterGui = game:GetService("StarterGui")
local UserInputService = game:GetService("UserInputService")

-- إشعار
local function Notify(title, text)
    pcall(function()
        StarterGui:SetCore("SendNotification", {
            Title = title,
            Text = text,
            Duration = 3,
            Icon = "rbxassetid://9079992154"
        })
    end)
end

-- تنظيف القديم
if _G.FRDesyncLoop then _G.FRDesyncLoop:Disconnect() end
if _G.FRStealLoop then _G.FRStealLoop:Disconnect() end

-- إعدادات
local NORMAL_SPEED = 40
local STEAL_SPEED = 15  -- سرعة السرقة 15
local UPDATE_DISTANCE = 30
local SEND_INTERVAL = 0.06

-- متغيرات
local IsStealing = false
local FakePosition = nil
local LastSendTime = 0

-- SetDesync
local function SetDesync(state)
    if typeof(rnet) == "table" then
        if rnet.setdesync then pcall(function() rnet.setdesync(state) end) end
        if rnet.desync then pcall(function() rnet.desync(state) end) end
    end
    if typeof(delta) == "table" then
        if delta.raknet_desync then pcall(function() delta.raknet_desync(state) end) end
        if delta.desync then pcall(function() delta.desync(state) end) end
    end
end

-- SendFakePosition
local function SendFakePosition(position)
    local now = tick()
    if now - LastSendTime < SEND_INTERVAL then return end
    LastSendTime = now
    
    local cf = CFrame.new(position)
    if typeof(rnet) == "table" then
        if rnet.sendphysics then pcall(function() rnet.sendphysics(cf) end) end
        if rnet.sendposition then pcall(function() rnet.sendposition(position) end) end
    end
    if typeof(delta) == "table" then
        if delta.sendphysics then pcall(function() delta.sendphysics(cf) end) end
        if delta.sendposition then pcall(function() delta.sendposition(position) end) end
    end
end

-- FastRespawn
local function FastRespawn()
    local char = LocalPlayer.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hrp or not hum then return end
    
    hrp.Velocity = Vector3.new(0, 0, 0)
    hrp.RotVelocity = Vector3.new(0, 0, 0)
    
    task.delay(0.05, function()
        if hum then hum:ChangeState(Enum.HumanoidStateType.Dead) end
    end)
end

-- === Insta Steal الأصلي ===
-- يخلي الـ Prompt HoldDuration = 0.08 (سريع جداً)
-- ويشتغل طوال الوقت على كل البوديومات
local function DoInstaSteal()
    pcall(function()
        local plots = workspace:FindFirstChild("Plots")
        if not plots then return end
        
        for _, plot in pairs(plots:GetChildren()) do
            local podiums = plot:FindFirstChild("AnimalPodiums")
            if podiums then
                for _, podium in pairs(podiums:GetChildren()) do
                    local base = podium:FindFirstChild("Base")
                    local spawn = base and base:FindFirstChild("Spawn")
                    local attachment = spawn and spawn:FindFirstChild("PromptAttachment")
                    
                    if attachment then
                        for _, child in pairs(attachment:GetChildren()) do
                            if child:IsA("ProximityPrompt") then
                                -- هذا يخلي التفاعل فوري (Insta)
                                child.HoldDuration = 0.08
                                -- يخلي المسافة أطول شوي عشان يسهل التفاعل
                                child.MaxActivationDistance = 8
                            end
                        end
                    end
                end
            end
        end
    end)
end

-- === Desync + Speed Loop ===
_G.FRDesyncLoop = RunService.Heartbeat:Connect(function()
    local char = LocalPlayer.Character
    if not char then return end
    
    local hrp = char:FindFirstChild("HumanoidRootPart")
    local humanoid = char:FindFirstChildOfClass("Humanoid")
    if not hrp or not humanoid then return end
    
    local realPos = hrp.Position
    local currentSpeed = IsStealing and STEAL_SPEED or NORMAL_SPEED
    
    -- Desync (نفس الأصلي)
    if not FakePosition then
        FakePosition = realPos
    end
    
    local distance = (realPos - FakePosition).Magnitude
    
    if distance > UPDATE_DISTANCE then
        local direction = (realPos - FakePosition).Unit
        FakePosition = FakePosition + (direction * 5)
        
        if (realPos - FakePosition).Magnitude < UPDATE_DISTANCE - 3 then
            FakePosition = realPos - (direction * (UPDATE_DISTANCE - 3))
        end
    end
    
    SendFakePosition(FakePosition)
    
    -- Speed
    humanoid.WalkSpeed = currentSpeed
end)

-- === Insta Steal Loop (طوال الوقت) ===
_G.FRStealLoop = RunService.Heartbeat:Connect(function()
    DoInstaSteal()
end)

-- === تفعيل تلقائي ===
task.spawn(function()
    task.wait(0.5)
    
    SetDesync(true)
    FastRespawn()
    
    local char = LocalPlayer.Character
    if char then
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if hrp then FakePosition = hrp.Position end
    end
    
    Notify("FR Auto", "✅ DESYNC + INSTA STEAL\nسرعة: 40 | سرقة: 15\nاضغط K للتبديل")
end)

-- === تبديل السرعة بزر K ===
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if input.KeyCode == Enum.KeyCode.K then
        IsStealing = not IsStealing
        Notify("FR Auto", IsStealing and "وضع السرقة: 15" or "الوضع العادي: 40")
    end
end)
