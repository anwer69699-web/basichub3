    local StatusLine = Instance.new("Frame", Button)
    StatusLine.Name = "StatusLine"
    StatusLine.Size = UDim2.new(0, 0, 0, 3)
    StatusLine.Position = UDim2.new(0, 0, 1, -3)
    StatusLine.BackgroundColor3 = specialColor or C.success
    StatusLine.BorderSizePixel = 0
    StatusLine.ZIndex = 25
    
    local isActive = false
    
    local function updateVisual(state)
        isActive = state
        
        if state then
            local onColor = specialColor or C.success
            
            TweenService:Create(Button, TweenInfo.new(0.25), {
                BackgroundColor3 = Color3.fromRGB(40, 50, 80),
                BackgroundTransparency = 0.05
            }):Play()
            
            TweenService:Create(Stroke, TweenInfo.new(0.25), {
                Color = onColor,
                Transparency = 0
            }):Play()
            
            TweenService:Create(Label, TweenInfo.new(0.25), {
                TextColor3 = onColor
            }):Play()
            
            TweenService:Create(IconLabel, TweenInfo.new(0.25), {
                TextColor3 = onColor
            }):Play()
            
            TweenService:Create(SwitchFrame, TweenInfo.new(0.25), {
                BackgroundColor3 = onColor
            }):Play()
            
            TweenService:Create(SwitchCircle, TweenInfo.new(0.3, Enum.EasingStyle.Back), {
                Position = UDim2.new(1, -18, 0.5, -8),
                BackgroundColor3 = Color3.fromRGB(255, 255, 255)
            }):Play()
            
            TweenService:Create(StatusLine, TweenInfo.new(0.3), {
                Size = UDim2.new(1, 0, 0, 3),
                BackgroundColor3 = onColor
            }):Play()
            
        else
            TweenService:Create(Button, TweenInfo.new(0.25), {
                BackgroundColor3 = Color3.fromRGB(25, 30, 50),
                BackgroundTransparency = 0.1
            }):Play()
            
            TweenService:Create(Stroke, TweenInfo.new(0.25), {
                Color = Color3.fromRGB(60, 80, 120),
                Transparency = 0.3
            }):Play()
            
            TweenService:Create(Label, TweenInfo.new(0.25), {
                TextColor3 = C.text
            }):Play()
            
            TweenService:Create(IconLabel, TweenInfo.new(0.25), {
                TextColor3 = specialColor or C.success
            }):Play()
            
            TweenService:Create(SwitchFrame, TweenInfo.new(0.25), {
                BackgroundColor3 = Color3.fromRGB(40, 40, 50)
            }):Play()
            
            TweenService:Create(SwitchCircle, TweenInfo.new(0.3, Enum.EasingStyle.Back), {
                Position = UDim2.new(0, 2, 0.5, -8),
                BackgroundColor3 = Color3.fromRGB(120, 120, 140)
            }):Play()
            
            TweenService:Create(StatusLine, TweenInfo.new(0.3), {
                Size = UDim2.new(0, 0, 0, 3)
            }):Play()
        end
    end
    
    Button.MouseButton1Click:Connect(function()
        print("CLICKED:", name)
        
        local newState = not isActive
        updateVisual(newState)
        
        local success, err = pcall(function()
            callback(newState)
        end)
        
        if not success then
            warn("Error in", name, ":", err)
            updateVisual(not newState)
        else
            print(name, ":", newState and "ON" or "OFF")
        end
        
        local ripple = Instance.new("Frame", Button)
        ripple.Size = UDim2.new(0, 0, 0, 0)
        ripple.Position = UDim2.new(0.5, 0, 0.5, 0)
        ripple.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
        ripple.BackgroundTransparency = 0.7
        ripple.BorderSizePixel = 0
        ripple.ZIndex = 19
        
        Instance.new("UICorner", ripple).CornerRadius = UDim.new(1, 0)
        
        TweenService:Create(ripple, TweenInfo.new(0.5), {
            Size = UDim2.new(2, 0, 2, 0),
            Position = UDim2.new(-0.5, 0, -0.5, 0),
            BackgroundTransparency = 1
        }):Play()
        
        task.delay(0.5, function()
            ripple:Destroy()
        end)
    end)
    
    Button.MouseEnter:Connect(function()
        print("Hover:", name)
        if not isActive then 
            TweenService:Create(Button, TweenInfo.new(0.15), {
                BackgroundTransparency = 0.05
            }):Play()
            TweenService:Create(Stroke, TweenInfo.new(0.15), {
                Transparency = 0.2
            }):Play()
        end
    end)
    
    Button.MouseLeave:Connect(function()
        if not isActive then 
            TweenService:Create(Button, TweenInfo.new(0.15), {
                BackgroundTransparency = 0.1
            }):Play()
            TweenService:Create(Stroke, TweenInfo.new(0.15), {
                Transparency = 0.3
            }):Play()
        end
    end)
    
    return Button, updateVisual
end

