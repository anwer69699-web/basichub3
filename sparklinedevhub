--// ============================================

local function AnalyzeCode(code)
    local layers = {}
    local workingCode = code
    
    --// البحث عن أنماط التشفير
    for _, pattern in ipairs(EncryptionPatterns) do
        local matches = {}
        for match in workingCode:gmatch(pattern.Pattern) do
            local success, decoded = pcall(function()
                return pattern.Decoder(match)
            end)
            if success and decoded then
                table.insert(matches, {
                    Original = match,
                    Decoded = decoded,
                    Pattern = pattern.Name
                })
            end
        end
        
        if #matches > 0 then
            table.insert(layers, {
                LayerName = pattern.Name,
                Matches = matches,
                Count = #matches
            })
        end
    end
    
    return layers
end

local function SimpleDeobfuscate(code)
    local result = code
    
    --// محاولة فك Base64
    result = result:gsub("([A-Za-z0-9+/]+={0,2})", function(str)
        if #str > 20 then
            local success, decoded = pcall(function()
                local b = 'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/'
                str = string.gsub(str, '[^'..b..'=]', '')
                return (str:gsub('.', function(x)
                    if (x == '=') then return '' end
                    local r,f='',(b:find(x)-1)
                    for i=6,1,-1 do r=r..(f%2^i-f%2^(i-1)>0 and '1' or '0') end
                    return r
                end):gsub('%d%d%d?%d?%d?%d?%d?%d?', function(x)
                    if (#x ~= 8) then return '' end
                    local c=0
                    for i=1,8 do c=c+(x:sub(i,i)=='1' and 2^(8-i) or 0) end
                    return string.char(c)
                end))
            end)
            if success and decoded and #decoded > 0 then
                return decoded
            end
        end
        return str
    end)
    
    --// تنظيف الأسماء العشوائية (بسيط)
    result = result:gsub("([%a_][%w_]+)", function(name)
        -- الكشف عن أسماء مشفرة عشوائية
        if #name > 15 and name:match("^[%a_]%w+$") then
            return "var_" .. name:sub(1, 8)
        end
        return name
    end)
    
    return result
end

