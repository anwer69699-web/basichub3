--// Core: AssemblyLinearVelocity (ASS) - UNCHANGED
--// Landing: REMOVED - Uses verticalSpeed directly like ascent
--// Made by sparklinedev

if getgenv().ARBIX_RUNNING then
    if getgenv().ARBIX_STOP then getgenv().ARBIX_STOP() end
end
getgenv().ARBIX_RUNNING = true

local Players = game:GetService("Players")
local Workspace = game:GetService("Workspace")
local RunService = game:GetService("RunService")
local TweenService = game:GetService("TweenService")

local player = Players.LocalPlayer

--⚡ CONFIG - ENHANCED SPEEDS (NO LANDING SYSTEM)
local config = {
    horizontalSpeed = 28,       --⚡ أسرع أفقي
    verticalSpeed = 35,         --⚡ أسرع عمودي (للصعود والهبوط)
    maxHeight = 15,             --⚡ ارتفاع أعلى
    stopDistance = 2.5,         --⚡ توقف فوري عند الاقتراب
    maxDistance = 2000,
    instantSnap = true          --⚡ تثبيت فوري عند الوصول
}

--🔧 VARIABLES
local char, hrp
local moving = false
local currentVelocity = Vector3.zero
local lastDir = Vector3.zero
local flyButton, statusLabel, distanceLabel
local gui, mainFrame
local connection = nil
local targetCache = nil
local lastTargetTime = 0
local deliveryHistory = {}

--🛑 STOP FUNCTION
getgenv().ARBIX_STOP = function()
    moving = false
    if connection then connection:Disconnect() connection=nil end
    if hrp then hrp.AssemblyLinearVelocity = Vector3.zero end
    if gui then gui:Destroy() end
    getgenv().ARBIX_RUNNING = false
end

--👤 CHARACTER SETUP
local function SetupCharacter(c)
    char = c
    hrp = char:WaitForChild("HumanoidRootPart")
    moving = false
    targetCache = nil
    if hrp then hrp.AssemblyLinearVelocity = Vector3.zero end
end
if player.Character then SetupCharacter(player.Character) end
player.CharacterAdded:Connect(SetupCharacter)

--🧠 SMOOTHING
local function Smooth(current, target, alpha)
    return current:Lerp(target, math.clamp(alpha, 0, 1))
end
local function StabilizeDirection(dir)
    if lastDir.Magnitude == 0 then
        lastDir = dir
        return dir
    end
    lastDir = lastDir:Lerp(dir, 0.35)
    return lastDir
end

--🎯 ENHANCED SMART FINDER
local function FindTarget()
    local currentTime = tick()
    
    if targetCache and (currentTime - lastTargetTime) < 0.2 then
        if targetCache.Parent then return targetCache end
    end
    
    local plots = Workspace:FindFirstChild("Plots")
    if not plots then return nil end
    
    local bestTarget = nil
    local bestScore = -math.huge
    local playerPos = hrp and hrp.Position or Vector3.zero
    
    for _, plot in pairs(plots:GetChildren()) do
        local sign = plot:FindFirstChild("PlotSign")
        if sign then
            local yourBase = sign:FindFirstChild("YourBase")
            if yourBase and yourBase.Enabled then
                local possibleTargets = {
                    plot:FindFirstChild("DeliveryHitbox"),
                    plot:FindFirstChild("DeliveryBox"),
                    plot:FindFirstChild("DeliveryZone"),
                    plot:FindFirstChild("DropZone"),
                    plot:FindFirstChild("Target")
                }
                
                for _, target in pairs(possibleTargets) do
                    if target and target:IsA("BasePart") then
                        local distance = (target.Position - playerPos).Magnitude
                        local score = 3000 - distance
                        
                        if distance < 20 then score = score + 2000 end
                        if deliveryHistory[target.Name] then score = score + 500 end
                        if distance > config.maxDistance then score = score - 3000 end
                        
                        if score > bestScore then
                            bestScore = score
                            bestTarget = target
                        end
                    end
                end
            end
        end
    end
    
    --🔍 بحث احتياطي
    if not bestTarget then
        for _, plot in pairs(plots:GetChildren()) do
            for _, obj in pairs(plot:GetDescendants()) do
                if obj:IsA("BasePart") then
                    local name = obj.Name:lower()
                    if name:find("delivery") or name:find("drop") or name:find("box") then
                        if hrp and (obj.Position - hrp.Position).Magnitude < config.maxDistance then
                            bestTarget = obj
                            break
                        end
                    end
                end
            end
            if bestTarget then break end
        end
    end
    
    if bestTarget then
        targetCache = bestTarget
        lastTargetTime = currentTime
    end
    
    return bestTarget
end

--🎯 PREDICTIVE POSITION
local function GetTargetPosition(target)
    if not target then return nil end
    if target:IsA("BasePart") and target.AssemblyLinearVelocity.Magnitude > 0.1 then
        local distance = hrp and (target.Position - hrp.Position).Magnitude or 0
        local predictTime = math.min(distance / config.horizontalSpeed, 1)
        return target.Position + (target.AssemblyLinearVelocity * predictTime * 0.3)
    end
    return target.Position
end

--🚀 INSTANT VERTICAL FLIGHT - NO LANDING LAG
local function MoveToTarget(target)
    if not hrp or not target then 
        UpdateStatus("❌ No Target", Color3.fromRGB(255,50,50))
        return 
    end
    
    moving = true
    
    if flyButton then
        flyButton.Text = "⏹️ STOP"
        flyButton.BackgroundColor3 = Color3.fromRGB(255,50,50)
    end
    UpdateStatus("🚀 FLYING...", Color3.fromRGB(0,255,150))
    
    local startPos = hrp.Position
    local targetPos = GetTargetPosition(target) or target.Position
    
    --⚡ حساب نقطة القمة فوق الهدف
    local distance = (targetPos - startPos).Magnitude
    local peakHeight = math.min(distance * 0.5, config.maxHeight)
    local peakPos = targetPos + Vector3.new(0, peakHeight, 0)
    
    local phase = "ASCENT"
    
    connection = RunService.Heartbeat:Connect(function(dt)
        if not moving or not hrp or not target.Parent then
            FinishDelivery(false)
            return
        end
        
        --🎯 تحديث الهدف إذا تحرك
        if target:IsA("BasePart") then
            targetPos = GetTargetPosition(target) or target.Position
            peakPos = targetPos + Vector3.new(0, peakHeight, 0)
        end
        
        local pos = hrp.Position
        local remainingToTarget = (targetPos - pos).Magnitude
        local remainingToPeak = (peakPos - pos).Magnitude
        
        --📊 تحديث المسافة
        UpdateDistance(remainingToTarget)
        
        --⚡ وصول فوري بدون لاق
        if remainingToTarget <= config.stopDistance then
            --⚡ INSTANT SNAP - NO LANDING LAG
            hrp.CFrame = CFrame.new(targetPos)
            hrp.AssemblyLinearVelocity = Vector3.zero
            FinishDelivery(true)
            return
        end
        
        --🎯 تحديد المرحلة
        local targetPoint
        if phase == "ASCENT" and remainingToPeak < 8 then
            phase = "DESCENT"
        end
        
        if phase == "ASCENT" then
            targetPoint = peakPos
            UpdateStatus("⬆️ UP", Color3.fromRGB(0,200,255))
        else
            targetPoint = targetPos
            UpdateStatus("⬇️ DOWN", Color3.fromRGB(255,200,0))
        end
        
        --🧮 حساب الاتجاه والسرعة - نفس السرعة للصعود والهبوط
        local dir = StabilizeDirection(targetPoint - pos)
        local horizontalDir = Vector3.new(dir.X, 0, dir.Z)
        
        --⚡ سرعة أفقية قصوى
        local horizontal = horizontalDir.Magnitude > 0.1 and horizontalDir.Unit * config.horizontalSpeed or Vector3.zero
        
        --⚡ سرعة عمودية - نفس السرعة للصعود والهبوط (NO LANDING SLOWDOWN)
        local verticalDist = targetPoint.Y - pos.Y
        local vertical = math.clamp(
            verticalDist * 5, --⚡ استجابة فورية
            -config.verticalSpeed, --⚡ نفس سرعة الهبوط = سرعة الصعود
            config.verticalSpeed
        )
        
        --⚡ تطبيق السرعة مباشرة
        local targetVelocity = Vector3.new(horizontal.X, vertical, horizontal.Z)
        currentVelocity = Smooth(currentVelocity, targetVelocity, math.clamp(dt * 12, 0, 1))
        hrp.AssemblyLinearVelocity = currentVelocity
    end)
end

--✅ FINISH
function FinishDelivery(success)
    moving = false
    if connection then connection:Disconnect() connection=nil end
    if hrp then hrp.AssemblyLinearVelocity = Vector3.zero end
    
    if success then
        UpdateStatus("✅ DELIVERED!", Color3.fromRGB(0,255,0))
        if targetCache then
            deliveryHistory[targetCache.Name] = (deliveryHistory[targetCache.Name] or 0) + 1
        end
    else
        UpdateStatus("❌ STOPPED", Color3.fromRGB(255,100,100))
    end
    
    if flyButton then
        flyButton.Text = "🚀 FLY TO DELIVERY"
        flyButton.BackgroundColor3 = Color3.fromRGB(0,150,255)
    end
end

--🎨 GUI FUNCTIONS
function UpdateStatus(text, color)
    if statusLabel then
        statusLabel.Text = text
        statusLabel.TextColor3 = color or Color3.fromRGB(255,255,255)
    end
end

function UpdateDistance(dist)
    if distanceLabel then
        distanceLabel.Text = "📏 " .. math.floor(dist) .. "m"
    end
end

--🖱️ DRAGGABLE
local function MakeDraggable(frame)
    local dragging, dragInput, dragStart, startPos
    frame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            dragStart = input.Position
            startPos = frame.Position
        end
    end)
    frame.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement then 
            dragInput = input 
        end
    end)
    RunService.RenderStepped:Connect(function()
        if dragging and dragInput then
            local delta = dragInput.Position - dragStart
            frame.Position = UDim2.new(
                startPos.X.Scale, startPos.X.Offset + delta.X,
                startPos.Y.Scale, startPos.Y.Offset + delta.Y
            )
        end
    end)
    frame.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)
end

