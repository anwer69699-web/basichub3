local Players = game:GetService("Players")
local Workspace = game:GetService("Workspace")
local RunService = game:GetService("RunService")
local player = Players.LocalPlayer

local moving = false
local char, hrp
local gui, flyButton

local config = {
    speed = 40, -- السرعة القصوى
    vertical = 20,
    flyHeight = 24,
    stopDistance = 3,
    correctKey = "arbix hub",
    acceleration = 120 -- تسارع أسرع
}

local function SetupCharacter(c)
    char = c
    hrp = char:WaitForChild("HumanoidRootPart")
end

if player.Character then
    SetupCharacter(player.Character)
end
player.CharacterAdded:Connect(SetupCharacter)

local function FindTarget()
    local plots = Workspace:FindFirstChild("Plots")
    if not plots then return end

    for _, plot in pairs(plots:GetChildren()) do
        local sign = plot:FindFirstChild("PlotSign")
        if sign then
            local yourBase = sign:FindFirstChild("YourBase")
            if yourBase and yourBase.Enabled then
                return plot:FindFirstChild("DeliveryHitbox")
            end
        end
    end
end

local function MoveToTarget(target)

    if not hrp or not target then return end

    moving = true
    flyButton.Text = "Stop"

    local targetHeight = hrp.Position.Y + config.flyHeight
    local currentSpeed = 0

    while moving and target.Parent do

        local dt = RunService.Heartbeat:Wait()

        local dir = target.Position - hrp.Position
        local dist = dir.Magnitude

        if dist <= config.stopDistance then break end

        -- تسارع سريع
        currentSpeed = math.clamp(
            currentSpeed + config.acceleration * dt,
            0,
            config.speed
        )

        -- إبطاء عند الاقتراب
        if dist < 12 then
            currentSpeed = math.min(currentSpeed, dist * 3)
        end

        local horizontalDir = Vector3.new(dir.X,0,dir.Z)

        local horizontal = Vector3.zero

        if horizontalDir.Magnitude > 0.1 then
            horizontal = horizontalDir.Unit * currentSpeed
        end

        -- تقليل السرعة القطرية
        if math.abs(horizontal.X) > 0 and math.abs(horizontal.Z) > 0 then
            horizontal = horizontal * 0.75
        end

        -- الارتفاع مع الحركة بنفس الوقت
        local y = 0

        if hrp.Position.Y < targetHeight then
            y = config.vertical
        end

        hrp.AssemblyLinearVelocity = Vector3.new(
            horizontal.X,
            y,
            horizontal.Z
        )

    end

    hrp.AssemblyLinearVelocity = Vector3.zero

    moving = false

    if flyButton then
        flyButton.Text = "Fly to Steal"
    end

end

local function MakeDraggable(frame)

    local dragging = false
    local dragInput, dragStart, startPos

    local function update(input)
        local delta = input.Position - dragStart

        frame.Position = UDim2.new(
            startPos.X.Scale,
            startPos.X.Offset + delta.X,
            startPos.Y.Scale,
            startPos.Y.Offset + delta.Y
        )
    end

    frame.InputBegan:Connect(function(input)

        if input.UserInputType == Enum.UserInputType.MouseButton1 then

            dragging = true
            dragStart = input.Position
            startPos = frame.Position

            input.Changed:Connect(function()

                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false
                end

            end)

        end

    end)

    frame.InputChanged:Connect(function(input)

        if input.UserInputType == Enum.UserInputType.MouseMovement then
            dragInput = input
        end

    end)

    RunService.RenderStepped:Connect(function()

        if dragging and dragInput then
            update(dragInput)
        end

    end)

end

local function CreateMainGUI(existingGUI)

    gui = existingGUI or Instance.new("ScreenGui")

    if not existingGUI then
        gui.Name = "ARBIX_HUB_GUI"
        gui.ResetOnSpawn = false
        gui.Parent = player:WaitForChild("PlayerGui")
    end

    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(0,250,0,120)
    frame.Position = UDim2.new(0.5,0,0.5,0)
    frame.AnchorPoint = Vector2.new(0.5,0.5)
    frame.BackgroundColor3 = Color3.fromRGB(20,20,30)
    frame.BackgroundTransparency = 0.1
    frame.Parent = gui

    Instance.new("UICorner", frame).CornerRadius = UDim.new(0,10)

    MakeDraggable(frame)

    local title = Instance.new("TextLabel")
    title.Size = UDim2.new(1,0,0,30)
    title.BackgroundTransparency = 1
    title.Text = "ARBIX HUB العربي"
    title.Font = Enum.Font.GothamBlack
    title.TextSize = 20
    title.TextColor3 = Color3.new(1,1,1)
    title.Parent = frame

    flyButton = Instance.new("TextButton")
    flyButton.Size = UDim2.new(0.8,0,0,30)
    flyButton.Position = UDim2.new(0.1,0,0.4,0)
    flyButton.Text = "Fly to Steal"
    flyButton.Font = Enum.Font.GothamBold
    flyButton.TextSize = 16
    flyButton.BackgroundColor3 = Color3.fromRGB(0,120,255)
    flyButton.TextColor3 = Color3.new(1,1,1)
    flyButton.Parent = frame

    Instance.new("UICorner", flyButton).CornerRadius = UDim.new(0,8)

    flyButton.MouseButton1Click:Connect(function()

        if moving then
            moving = false
            return
        end

        local target = FindTarget()

        if target then
            MoveToTarget(target)
        end

    end)

    local close = Instance.new("TextButton")
    close.Size = UDim2.new(0.1,0,0.3,0)
    close.Position = UDim2.new(0.9,0,0,0)
    close.Text = "X"
    close.Font = Enum.Font.GothamBold
    close.TextSize = 16
    close.TextColor3 = Color3.new(1,1,1)
    close.BackgroundColor3 = Color3.fromRGB(200,50,50)
    close.Parent = frame

    Instance.new("UICorner", close).CornerRadius = UDim.new(0,5)

    close.MouseButton1Click:Connect(function()
        gui:Destroy()
    end)

end

