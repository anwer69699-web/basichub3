-- سحب
local dragging, dragStart, startPos
Header.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true
        dragStart = input.Position
        startPos = MainFrame.Position
    end
end)

Header.InputChanged:Connect(function(input)
    if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
        local delta = input.Position - dragStart
        MainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, 
                                       startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)

Header.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
end)

-- دوال Desync
local function SetDesync(state)
    if typeof(rnet) == "table" then
        if rnet.setdesync then pcall(function() rnet.setdesync(state) end) end
        if rnet.desync then pcall(function() rnet.desync(state) end) end
    end
    if typeof(delta) == "table" then
        if delta.raknet_desync then pcall(function() delta.raknet_desync(state) end) end
        if delta.desync then pcall(function() delta.desync(state) end) end
    end
end

local function SendPosition(pos)
    local now = tick()
    if now - LastSendTime < SEND_INTERVAL then return end
    LastSendTime = now
    
    local cf = CFrame.new(pos)
    if typeof(rnet) == "table" then
        if rnet.sendphysics then pcall(function() rnet.sendphysics(cf) end) end
        if rnet.sendposition then pcall(function() rnet.sendposition(pos) end) end
    end
    if typeof(delta) == "table" then
        if delta.sendphysics then pcall(function() delta.sendphysics(cf) end) end
        if delta.sendposition then pcall(function() delta.sendposition(pos) end) end
    end
end

