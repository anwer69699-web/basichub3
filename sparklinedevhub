-- FR Mini - Insta Steal + Desync + Speed

local P = game:GetService("Players").LocalPlayer
local R = game:GetService("RunService")
local S = game:GetService("StarterGui")
local U = game:GetService("UserInputService")
local T = game:GetService("TweenService")

-- حذف القديم
for _, v in pairs(P:WaitForChild("PlayerGui"):GetChildren()) do
    if v.Name:match("FRMini") then v:Destroy() end
end
if _G.FRMiniLoop then _G.FRMiniLoop:Disconnect() _G.FRMiniLoop = nil end
if _G.FRStealLoop then _G.FRStealLoop:Disconnect() _G.FRStealLoop = nil end

-- إعدادات
local SPEED = 40
local STEAL_SPEED = 20
local DESYNC_DELAY = 0.25  -- تجديد متأخر (كل 0.25 ثانية)
local UPDATE_DIST = 13     -- يجدد فقط إذا تجاوزت 20 متر

-- متغيرات
local Enabled = false
local Stealing = false
local FakePos = nil
local LastUpdate = 0
local LastSend = 0

-- إشعار
local function N(m)
    pcall(function() S:SetCore("SendNotification", {Title="FR",Text=m,Duration=2}) end)
end

-- Insta Steal
local function StealLoop()
    _G.FRStealLoop = R.Heartbeat:Connect(function()
        if not Stealing then return end
        pcall(function()
            local plots = workspace:FindFirstChild("Plots")
            if not plots then return end
            for _, plot in pairs(plots:GetChildren()) do
                local pods = plot:FindFirstChild("AnimalPodiums")
                if pods then
                    for _, pod in pairs(pods:GetChildren()) do
                        local base = pod:FindFirstChild("Base")
                        local sp = base and base:FindFirstChild("Spawn")
                        local att = sp and sp:FindFirstChild("PromptAttachment")
                        if att then
                            for _, pr in pairs(att:GetChildren()) do
                                if pr:IsA("ProximityPrompt") then
                                    pr.HoldDuration = 0.08  -- سريع جداً
                                end
                            end
                        end
                    end
                end
            end
        end)
    end)
end

-- Desync + Speed
local function MainLoop()
    _G.FRMiniLoop = R.Heartbeat:Connect(function()
        if not Enabled then return end
        
        local c = P.Character
        if not c then return end
        local hrp = c:FindFirstChild("HumanoidRootPart")
        local hum = c:FindFirstChildOfClass("Humanoid")
        if not hrp or not hum then return end
        
        local realPos = hrp.Position
        local speed = Stealing and STEAL_SPEED or SPEED
        
        -- === DESYNC (تجديد متأخر) ===
        if not FakePos then FakePos = realPos end
        
        local dist = (realPos - FakePos).Magnitude
        local now = tick()
        
        -- يجدد فقط كل DESYNC_DELAY وإذا تجاوزت المسافة
        if now - LastUpdate >= DESYNC_DELAY then
            LastUpdate = now
            
            -- يتحرك ببطء نحو اللاعب (يعيق العدو)
            if dist > UPDATE_DIST then
                local dir = (realPos - FakePos).Unit
                FakePos = FakePos + (dir * 8)  -- خطوة صغيرة (بطيئة)
                
                -- يحافظ على المسافة
                if (realPos - FakePos).Magnitude < UPDATE_DIST - 5 then
                    FakePos = realPos - (dir * (UPDATE_DIST - 5))
                end
            end
            
            -- إرسال للسيرفر (بطيء)
            if now - LastSend >= 0.15 then
                LastSend = now
                local cf = CFrame.new(FakePos)
                if typeof(rnet) == "table" then
                    if rnet.sendposition then pcall(function() rnet.sendposition(FakePos) end) end
                    if rnet.sendphysics then pcall(function() rnet.sendphysics(cf) end) end
                end
                if typeof(delta) == "table" then
                    if delta.sendposition then pcall(function() delta.sendposition(FakePos) end) end
                    if delta.sendphysics then pcall(function() delta.sendphysics(cf) end) end
                end
            end
        end
        
        -- === SPEED BOOST ===
        hum.WalkSpeed = 28  -- آمن للسيرفر
        
        -- سرعة حقيقية بـ AssemblyLinearVelocity
        if speed > 28 and hum.MoveDirection.Magnitude > 0.1 then
            local vel = hrp.AssemblyLinearVelocity
            local target = hum.MoveDirection * speed
            hrp.AssemblyLinearVelocity = Vector3.new(
                vel.X + (target.X - vel.X) * 0.12,
                vel.Y,
                vel.Z + (target.Z - vel.Z) * 0.12
            )
        end
    end)
end

-- واجهة صغيرة جداً
local SG = Instance.new("ScreenGui")
SG.Name = "FRMiniV1"
SG.ResetOnSpawn = false
SG.Parent = P:WaitForChild("PlayerGui")

local F = Instance.new("Frame")
F.Size = UDim2.new(0, 90, 0, 70)
F.Position = UDim2.new(0.5, -45, 0.85, -35)
F.BackgroundColor3 = Color3.fromRGB(20, 20, 25)
F.BorderSizePixel = 0
F.Parent = SG
Instance.new("UICorner", F).CornerRadius = UDim.new(0, 8)

-- عنوان صغير
local Tt = Instance.new("TextLabel")
Tt.Size = UDim2.new(1, 0, 0, 18)
Tt.BackgroundColor3 = Color3.fromRGB(35, 35, 45)
Tt.Text = "FR Mini"
Tt.TextColor3 = Color3.fromRGB(0, 200, 255)
Tt.TextSize = 10
Tt.Font = Enum.Font.GothamBold
Tt.Parent = F
Instance.new("UICorner", Tt).CornerRadius = UDim.new(0, 6)

-- زر Desync
local Dbtn = Instance.new("TextButton")
Dbtn.Size = UDim2.new(0.9, 0, 0, 20)
Dbtn.Position = UDim2.new(0.05, 0, 0.32, 0)
Dbtn.BackgroundColor3 = Color3.fromRGB(150, 30, 30)
Dbtn.Text = "Desync"
Dbtn.TextColor3 = Color3.fromRGB(255, 255, 255)
Dbtn.TextSize = 10
Dbtn.Font = Enum.Font.GothamBold
Dbtn.Parent = F
Instance.new("UICorner", Dbtn).CornerRadius = UDim.new(0, 5)

-- زر Insta Steal
local Sbtn = Instance.new("TextButton")
Sbtn.Size = UDim2.new(0.9, 0, 0, 20)
Sbtn.Position = UDim2.new(0.05, 0, 0.62, 0)
Sbtn.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
Sbtn.Text = "Insta Steal"
Sbtn.TextColor3 = Color3.fromRGB(200, 200, 200)
Sbtn.TextSize = 10
Sbtn.Font = Enum.Font.GothamBold
Sbtn.Parent = F
Instance.new("UICorner", Sbtn).CornerRadius = UDim.new(0, 5)

-- سحب
local d, ds, sp
F.InputBegan:Connect(function(i)
    if i.UserInputType == Enum.UserInputType.MouseButton1 then
        d = true
        ds = i.Position
        sp = F.Position
    end
end)
F.InputChanged:Connect(function(i)
    if d and i.UserInputType == Enum.UserInputType.MouseMovement then
        local delta = i.Position - ds
        F.Position = UDim2.new(sp.X.Scale, sp.X.Offset + delta.X, sp.Y.Scale, sp.Y.Offset + delta.Y)
    end
end)
F.InputEnded:Connect(function(i)
    if i.UserInputType == Enum.UserInputType.MouseButton1 then d = false end
end)

-- تفعيل Desync
Dbtn.MouseButton1Click:Connect(function()
    Enabled = not Enabled
    if Enabled then
        FakePos = nil
        MainLoop()
        T:Create(Dbtn, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(0, 150, 100)}):Play()
        N("Desync: ON (تجديد متأخر)")
    else
        if _G.FRMiniLoop then _G.FRMiniLoop:Disconnect() _G.FRMiniLoop = nil end
        FakePos = nil
        local c = P.Character
        if c then
            local h = c:FindFirstChildOfClass("Humanoid")
            if h then h.WalkSpeed = 16 end
        end
        T:Create(Dbtn, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(150, 30, 30)}):Play()
        N("Desync: OFF")
    end
end)

-- تفعيل Steal
Sbtn.MouseButton1Click:Connect(function()
    Stealing = not Stealing
    if Stealing then
        StealLoop()
        T:Create(Sbtn, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(255, 150, 0)}):Play()
        N("Insta Steal: ON")
    else
        if _G.FRStealLoop then _G.FRStealLoop:Disconnect() _G.FRStealLoop = nil end
        T:Create(Sbtn, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(30, 30, 30)}):Play()
        N("Insta Steal: OFF")
    end
end)

N("FR Mini جاهز!")
