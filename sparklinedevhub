-- سحب النافذة
local dragging, dragInput, dragStart, startPos
local function update(input)
    local delta = input.Position - dragStart
    MainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
end
MainFrame.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = MainFrame.Position
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then dragging = false end
        end)
    end
end)
MainFrame.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then dragInput = input end
end)
UserInputService.InputChanged:Connect(function(input)
    if input == dragInput and dragging then update(input) end
end)

-- إعدادات السرعة
local NORMAL_SPEED = 40
local STEAL_SPEED = 27
local UPDATE_DISTANCE = 15
local SEND_INTERVAL = 0.12

-- متغيرات Desync
local DesyncEnabled = false
local IsStealing = false
local Connection_RenderStepped = nil
local FakePosition = nil
local LastSendTime = 0

local function SetDesync(state)
    if state then
        if typeof(rnet) == "table" then
            if rnet.setdesync then pcall(function() rnet.setdesync(true) end) end
            if rnet.desync then pcall(function() rnet.desync(true) end) end
        end
        if typeof(delta) == "table" then
            if delta.raknet_desync then pcall(function() delta.raknet_desync(true) end) end
            if delta.desync then pcall(function() delta.desync(true) end) end
        end
    else
        if typeof(rnet) == "table" then
            if rnet.setdesync then pcall(function() rnet.setdesync(false) end) end
            if rnet.desync then pcall(function() rnet.desync(false) end) end
        end
        if typeof(delta) == "table" then
            if delta.raknet_desync then pcall(function() delta.raknet_desync(false) end) end
            if delta.desync then pcall(function() delta.desync(false) end) end
        end
    end
end

local function SendFakePosition(position)
    local now = tick()
    if now - LastSendTime < SEND_INTERVAL then return end
    LastSendTime = now
    
    local cf = CFrame.new(position)
    if typeof(rnet) == "table" then
        if rnet.sendphysics then pcall(function() rnet.sendphysics(cf) end) end
        if rnet.sendposition then pcall(function() rnet.sendposition(position) end) end
    end
    if typeof(delta) == "table" then
        if delta.sendphysics then pcall(function() delta.sendphysics(cf) end) end
        if delta.sendposition then pcall(function() delta.sendposition(position) end) end
    end
end

local function GetServerPosition()
    if typeof(delta) == "table" and delta.get_server_position then
        local success, pos = pcall(delta.get_server_position)
        if success and pos and typeof(pos) == "Vector3" then return pos end
    end
    if typeof(rnet) == "table" and rnet.get_server_position then
        local success, pos = pcall(rnet.get_server_position)
        if success and pos and typeof(pos) == "Vector3" then return pos end
    end
    return nil
end

function FastRespawn()
    local char = LocalPlayer.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hrp or not hum then return end
    
    hrp.Velocity = Vector3.new(0, 0, 0)
    hrp.RotVelocity = Vector3.new(0, 0, 0)
    
    task.delay(0.05, function()
        if hum then hum:ChangeState(Enum.HumanoidStateType.Dead) end
    end)
end

