-- الدالة الرئيسية
local function UpdateDesync()
    local char = LocalPlayer.Character
    if not char then return end
    
    local hrp = char:FindFirstChild("HumanoidRootPart")
    local humanoid = char:FindFirstChildOfClass("Humanoid")
    if not hrp or not humanoid then return end
    
    local realPos = hrp.Position
    local speed = IsStealing and STEAL_SPEED or NORMAL_SPEED
    
    if not FakePosition then FakePosition = realPos end
    
    local distance = (realPos - FakePosition).Magnitude
    
    if distance > UPDATE_DISTANCE then
        local dir = (realPos - FakePosition).Unit
        FakePosition = FakePosition + (dir * 6)
        if (realPos - FakePosition).Magnitude < UPDATE_DISTANCE - 3 then
            FakePosition = realPos - (dir * (UPDATE_DISTANCE - 3))
        end
    end
    
    SendPosition(FakePosition)
    humanoid.WalkSpeed = speed
    
    if tick() % 0.3 < 0.05 then
        DistLabel.Text = "المسافة: " .. math.floor(distance) .. "m"
        StatusLabel.Text = distance > 10 and "Desync نشط" or "قريب"
        StatusLabel.TextColor3 = distance > 10 and Color3.fromRGB(100, 255, 100) or Color3.fromRGB(255, 200, 0)
    end
end

-- تفعيل/إيقاف
local function Toggle()
    DesyncEnabled = not DesyncEnabled
    
    if DesyncEnabled then
        local char = LocalPlayer.Character
        if char then
            local hrp = char:FindFirstChild("HumanoidRootPart")
            if hrp then FakePosition = hrp.Position end
        end
        
        SetDesync(true)
        
        -- Fast respawn خفيف
        task.spawn(function()
            local c = LocalPlayer.Character
            if c then
                local h = c:FindFirstChildOfClass("Humanoid")
                if h then
                    task.wait(0.05)
                    h:ChangeState(Enum.HumanoidStateType.Dead)
                end
            end
        end)
        
        _G.FRHUB_DESYNC_CONNECTION = RunService.Heartbeat:Connect(UpdateDesync)
        
        TweenService:Create(ToggleBtn, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(0, 170, 127)}):Play()
        ToggleBtn.Text = "Desync: مفعل"
        Notify("FR HUB", "V13 نشط!", 2)
    else
        if _G.FRHUB_DESYNC_CONNECTION then
            _G.FRHUB_DESYNC_CONNECTION:Disconnect()
            _G.FRHUB_DESYNC_CONNECTION = nil
        end
        
        SetDesync(false)
        FakePosition = nil
        
        local char = LocalPlayer.Character
        if char then
            local h = char:FindFirstChildOfClass("Humanoid")
            if h then h.WalkSpeed = 16 end
        end
        
        TweenService:Create(ToggleBtn, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(45, 45, 45)}):Play()
        ToggleBtn.Text = "تفعيل Desync"
        StatusLabel.Text = "متوقف"
        StatusLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
        
        Notify("FR HUB", "تم الإيقاف", 2)
    end
end

