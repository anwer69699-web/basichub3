--// أنماط التشفيرات الشائعة
local EncryptionPatterns = {
    {
        Name = "Base64",
        Pattern = "([A-Za-z0-9+/]+={0,2})",
        Decoder = function(str)
            -- Base64 decoder بسيط
            local b = 'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/'
            str = string.gsub(str, '[^'..b..'=]', '')
            return (str:gsub('.', function(x)
                if (x == '=') then return '' end
                local r,f='',(b:find(x)-1)
                for i=6,1,-1 do r=r..(f%2^i-f%2^(i-1)>0 and '1' or '0') end
                return r
            end):gsub('%d%d%d?%d?%d?%d?%d?%d?', function(x)
                if (#x ~= 8) then return '' end
                local c=0
                for i=1,8 do c=c+(x:sub(i,i)=='1' and 2^(8-i) or 0) end
                return string.char(c)
            end))
        end
    },
    {
        Name = "Hex Escape",
        Pattern = "\\x([0-9A-Fa-f][0-9A-Fa-f])",
        Decoder = function(hex)
            return string.char(tonumber(hex, 16))
        end
    },
    {
        Name = "String Reverse",
        Pattern = "string%.reverse%([\"']([^\"']+)[\"']%)",
        Decoder = function(str)
            return string.reverse(str)
        end
    },
    {
        Name = "Char Code",
        Pattern = "string%.char%(([%d%s,]+)%)",
        Decoder = function(codes)
            local result = ""
            for num in codes:gmatch("%d+") do
                result = result .. string.char(tonumber(num))
            end
            return result
        end
    },
    {
        Name = "Loadstring Pattern",
        Pattern = "loadstring%((.-)%)%(%)",
        Decoder = function(code)
            return "--// Decoded Loadstring Content:\\n" .. code
        end
    }
}

