Instance.new("UICorner", Dbtn).CornerRadius = UDim.new(0, 5)

-- زر Steal (مطفي - رمادي)
local Sbtn = Instance.new("TextButton")
Sbtn.Size = UDim2.new(0.9, 0, 0, 22)
Sbtn.Position = UDim2.new(0.05, 0, 0.65, 0)
Sbtn.BackgroundColor3 = Color3.fromRGB(60, 60, 65)  -- رمادي (مطفي)
Sbtn.Text = "Steal: OFF"
Sbtn.TextColor3 = Color3.fromRGB(150, 150, 150)
Sbtn.TextSize = 10
Sbtn.Font = Enum.Font.GothamBold
Sbtn.Parent = F
Instance.new("UICorner", Sbtn).CornerRadius = UDim.new(0, 5)

-- سحب
local d, ds, sp
F.InputBegan:Connect(function(i)
    if i.UserInputType == Enum.UserInputType.MouseButton1 then
        d = true
        ds = i.Position
        sp = F.Position
    end
end)
F.InputChanged:Connect(function(i)
    if d and i.UserInputType == Enum.UserInputType.MouseMovement then
        local delta = i.Position - ds
        F.Position = UDim2.new(sp.X.Scale, sp.X.Offset + delta.X, sp.Y.Scale, sp.Y.Offset + delta.Y)
    end
end)
F.InputEnded:Connect(function(i)
    if i.UserInputType == Enum.UserInputType.MouseButton1 then d = false end
end)

-- تفعيل Desync
Dbtn.MouseButton1Click:Connect(function()
    DesyncEnabled = not DesyncEnabled
    
    if DesyncEnabled then
        -- شغل
        FakePos = nil
        MainLoop()
        T:Create(Dbtn, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(0, 150, 100)}):Play()
        Dbtn.Text = "Desync: ON"
        Dbtn.TextColor3 = Color3.fromRGB(255, 255, 255)
        N("Desync ON")
    else
        -- طفي
        if _G.FRMiniLoop then _G.FRMiniLoop:Disconnect() _G.FRMiniLoop = nil end
        FakePos = nil
        local c = P.Character
        if c then
            local h = c:FindFirstChildOfClass("Humanoid")
            if h then h.WalkSpeed = 16 end
        end
        T:Create(Dbtn, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(60, 60, 65)}):Play()
        Dbtn.Text = "Desync: OFF"
        Dbtn.TextColor3 = Color3.fromRGB(150, 150, 150)
        N("Desync OFF")
    end
end)

-- تفعيل Steal
Sbtn.MouseButton1Click:Connect(function()
    StealEnabled = not StealEnabled
    
    if StealEnabled then
        -- شغل
        StealLoop()
        T:Create(Sbtn, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(0, 120, 200)}):Play()
        Sbtn.Text = "Steal: ON"
        Sbtn.TextColor3 = Color3.fromRGB(255, 255, 255)
        N("Steal ON")
    else
        -- طفي
        if _G.FRStealLoop then _G.FRStealLoop:Disconnect() _G.FRStealLoop = nil end
        T:Create(Sbtn, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(60, 60, 65)}):Play()
        Sbtn.Text = "Steal: OFF"
        Sbtn.TextColor3 = Color3.fromRGB(150, 150, 150)
        N("Steal OFF")
    end
end)

N("FR Mini V2 جاهز!")
