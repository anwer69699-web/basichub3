-- الدالة الرئيسية (بدون SendPosition، بدون FakePosition)
local function ApplyVelocity()
    local now = tick()
    if now - LastUpdate < UpdateInterval then return end
    LastUpdate = now
    
    local char = LocalPlayer.Character
    if not char then return end
    
    local hrp = char:FindFirstChild("HumanoidRootPart")
    local humanoid = char:FindFirstChildOfClass("Humanoid")
    if not hrp or not humanoid then return end
    
    local targetSpeed = IsStealing and STEAL_SPEED or NORMAL_SPEED
    
    -- 1. تطبيق WalkSpeed الآمن (28 كحد أقصى)
    humanoid.WalkSpeed = math.min(targetSpeed, WALK_SPEED_CAP)
    
    -- 2. إذا السرعة أعلى من 28، نكمل بـ AssemblyLinearVelocity (بدون إرسال موقع)
    if targetSpeed > WALK_SPEED_CAP and humanoid.MoveDirection.Magnitude > 0.1 then
        local currentVel = hrp.AssemblyLinearVelocity
        local targetVel = humanoid.MoveDirection * targetSpeed
        
        -- تسارع سلس (Lerp)
        local smoothFactor = 0.12
        local newVel = Vector3.new(
            currentVel.X + (targetVel.X - currentVel.X) * smoothFactor,
            currentVel.Y,  -- نحافظ على الجاذبية الطبيعية
            currentVel.Z + (targetVel.Z - currentVel.Z) * smoothFactor
        )
        
        hrp.AssemblyLinearVelocity = newVel
    end
end

-- تفعيل/إيقاف
local function Toggle()
    Enabled = not Enabled
    
    if Enabled then
        VelocityConnection = RunService.Heartbeat:Connect(ApplyVelocity)
        
        TweenService:Create(ToggleBtn, TweenInfo.new(0.2), {
            BackgroundColor3 = Color3.fromRGB(0, 170, 127)
        }):Play()
        ToggleBtn.Text = "إيقاف السرعة"
        StatusLabel.Text = IsStealing and "سرقة: 27" or "عادي: 40"
        StatusLabel.TextColor3 = Color3.fromRGB(100, 255, 100)
        
        Notify("FR HUB", "السرعة: " .. (IsStealing and STEAL_SPEED or NORMAL_SPEED), 2)
    else
        if VelocityConnection then
            VelocityConnection:Disconnect()
            VelocityConnection = nil
        end
        
        -- إعادة السرعة الطبيعية
        local char = LocalPlayer.Character
        if char then
            local humanoid = char:FindFirstChildOfClass("Humanoid")
            if humanoid then humanoid.WalkSpeed = 16 end
        end
        
        TweenService:Create(ToggleBtn, TweenInfo.new(0.2), {
            BackgroundColor3 = Color3.fromRGB(45, 45, 45)
        }):Play()
        ToggleBtn.Text = "تفعيل السرعة"
        StatusLabel.Text = "متوقف"
        StatusLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
        
        Notify("FR HUB", "تم الإيقاف", 2)
    end
end

