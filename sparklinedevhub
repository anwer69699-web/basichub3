-- Rubber Banding محسّن (بمعدل أقل)
local RubberPart, RubberHighlight, RubberLabel, RubberConn
local LastRBUpdate = 0
local RBInterval = 0.1 -- تحديث كل 0.1 ثانية

function StartRB()
    if RubberConn then RubberConn:Disconnect() end
    if RubberPart then RubberPart:Destroy() end
    if RubberHighlight then RubberHighlight:Destroy() end
    if RubberLabel then RubberLabel:Destroy() end

    RubberPart = Instance.new("Part")
    RubberPart.Size = Vector3.new(4, 6, 4)
    RubberPart.Anchored = true
    RubberPart.CanCollide = false
    RubberPart.Transparency = 1
    RubberPart.Parent = workspace

    RubberHighlight = Instance.new("BoxHandleAdornment")
    RubberHighlight.Size = Vector3.new(4, 6, 4)
    RubberHighlight.Color3 = Color3.fromRGB(0, 255, 0)
    RubberHighlight.Transparency = 0.25
    RubberHighlight.AlwaysOnTop = true
    RubberHighlight.Adornee = RubberPart
    RubberHighlight.Parent = workspace

    RubberLabel = Instance.new("BillboardGui")
    RubberLabel.Size = UDim2.new(0, 200, 0, 50)
    RubberLabel.AlwaysOnTop = true
    RubberLabel.Adornee = RubberPart
    RubberLabel.Parent = workspace

    local txt = Instance.new("TextLabel")
    txt.Size = UDim2.new(1, 0, 1, 0)
    txt.BackgroundTransparency = 1
    txt.Text = "مكانك"
    txt.TextColor3 = Color3.fromRGB(0, 255, 0)
    txt.TextStrokeTransparency = 0
    txt.TextSize = 14
    txt.Font = Enum.Font.GothamBold
    txt.Parent = RubberLabel

    local lastPos = nil

    RubberConn = RunService.Heartbeat:Connect(function(dt)
        -- تحديث بمعدل محدود
        local now = tick()
        if now - LastRBUpdate < RBInterval then return end
        LastRBUpdate = now
        
        local char = LocalPlayer.Character
        local hrp = char and char:FindFirstChild("HumanoidRootPart")
        if not hrp then return end

        local currentPos = hrp.Position
        local velocity = hrp.Velocity

        if lastPos then
            local delta = (currentPos - lastPos)
            local dist = delta.Magnitude
            local maxPossible = velocity.Magnitude * dt + 2
            local predicted = lastPos + (velocity * dt)
            local errorDist = (currentPos - predicted).Magnitude

            if dist > 2 and errorDist > 3 and dist > maxPossible then
                RubberPart.CFrame = CFrame.new(currentPos)
            end
        end

        lastPos = currentPos
    end)
end

function StopRB()
    if RubberConn then RubberConn:Disconnect() end
    if RubberHighlight then RubberHighlight:Destroy() end
    if RubberPart then RubberPart:Destroy() end
    if RubberLabel then RubberLabel:Destroy() end
end

