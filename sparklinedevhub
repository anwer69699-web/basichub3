if not success then
warn("[Logger] Error: " .. tostring(err))
end
end
-- // [5] GUI HANDLING //
local function setupGUI()
-- Identify the container created by the loader/script
UI.Root = CoreGui:FindFirstChild("cfb0452a9801a6a4416a00c98735b5e90ab71d1301eb5af748d852dbde87f11b")
or CoreGui:FindFirstChild(CONFIG.Names.ScreenGui)
if not UI.Root then return end
local ScreenGui = UI.Root:FindFirstChild(CONFIG.Names.ScreenGui) or UI.Root
UI.MainFrame = ScreenGui:FindFirstChildOfClass("Frame")
if UI.MainFrame then
UI.MainFrame.Active = true
UI.MainFrame.Draggable = true
UI.MainFrame.Name = CONFIG.Names.MainFrame
-- Map out children dynamically
for _, child in ipairs(UI.MainFrame:GetDescendants()) do
if child:IsA("TextButton") then
table.insert(UI.Buttons, child)
elseif child:IsA("TextLabel") then
table.insert(UI.Labels, child)
end
end
end
end
-- // [6] FUNCTIONALITY //
local function toggleLagger()
State.LaggerEnabled = not State.LaggerEnabled
-- Visual Feedback Logic
local container = UI.MainFrame:FindFirstChild("Frame") -- Enable Lagger Row
if container then
local indicator = container:FindFirstChild("Frame") -- Toggle Background
local ball = indicator and indicator:FindFirstChild("Frame")
if ball then
ball:TweenPosition(
State.LaggerEnabled and UDim2.new(1, -16, 0.5, -7) or UDim2.new(0, 2, 0.5, -7),
"Out", "Quad", 0.2, true
)
indicator.BackgroundColor3 = State.LaggerEnabled and CONFIG.Colors.Enabled or CONFIG.Colors.Accent
end
end
end
local function handleInputs()
UserInputService.InputBegan:Connect(function(input, gpe)
if gpe then return end
if input.KeyCode == State.CurrentKeybind then
UI.MainFrame.Visible = not UI.MainFrame.Visible
end
end)
end
local function connectEvents()
-- Minimize Button logic
local minimizeBtn = UI.MainFrame:FindFirstChild("TextButton")
if minimizeBtn then
minimizeBtn.MouseButton1Click:Connect(function()
UI.MainFrame.Visible = false
end)
end
-- Toggle Button logic
for _, btn in ipairs(UI.Buttons) do
if btn.Parent.Name == "Frame" and btn.Text == "" then -- Detected toggle overlay
btn.MouseButton1Click:Connect(toggleLagger)
end
end
end
