local Players = game:GetService("Players")
local Workspace = game:GetService("Workspace")
local RunService = game:GetService("RunService")

local player = Players.LocalPlayer

-- ================= CONFIG =================
local config = {
    horizontalSpeed = 29,
    verticalSpeed = 27,
    maxHeight = 14,
    stopDistance = 3,
    correctKey = "arbix hub"
}
-- =========================================

local moving = false
local char, hrp
local gui, flyButton
local currentVelocity = Vector3.zero
local lastDir = Vector3.zero

-- ================== Character Setup ==================
local function SetupCharacter(c)
    char = c
    hrp = char:WaitForChild("HumanoidRootPart")
end

if player.Character then
    SetupCharacter(player.Character)
end
player.CharacterAdded:Connect(SetupCharacter)

-- ================== Helpers ==================
local function Smooth(current,target,alpha)
    return current:Lerp(target,alpha)
end

local function StabilizeDirection(dir)
    if lastDir.Magnitude == 0 then
        lastDir = dir
        return dir
    end
    lastDir = lastDir:Lerp(dir,0.25)
    return lastDir
end

local function FindTarget()
    local plots = Workspace:FindFirstChild("Plots")
    if not plots then return end
    for _, plot in pairs(plots:GetChildren()) do
        local sign = plot:FindFirstChild("PlotSign")
        if sign then
            local yourBase = sign:FindFirstChild("YourBase")
            if yourBase and yourBase.Enabled then
                return plot:FindFirstChild("DeliveryHitbox")
            end
        end
    end
end

-- ================== MoveToTarget ==================
local function MoveToTarget(target)
    if not hrp or not target then return end
    moving = true
    flyButton.Text = "Stop"

    local startPos = hrp.Position
    local traveled = 0
    local totalDistance = (target.Position - startPos).Magnitude

    while moving and target.Parent do
        local dt = RunService.Heartbeat:Wait()
        local pos = hrp.Position
        local dir = target.Position - pos
        local dist = dir.Magnitude
        if dist <= config.stopDistance then break end

        dir = StabilizeDirection(dir)

        -- Horizontal speed fluctuation ±1
        local fluctuation = math.random(-1,1)
        local horizontalSpeed = config.horizontalSpeed + fluctuation

        local horizontalDir = Vector3.new(dir.X,0,dir.Z)
        local horizontal = Vector3.zero
        if horizontalDir.Magnitude > 0.1 then
            horizontal = horizontalDir.Unit * horizontalSpeed
        end

        traveled = traveled + (horizontal.Magnitude * dt)
        local progress = math.clamp(traveled / totalDistance,0,1)

        -- Curved jump arc
        local heightOffset = math.sin(progress * math.pi) * config.maxHeight
        local targetY = target.Position.Y + heightOffset
        local heightError = targetY - pos.Y
        local y = math.clamp(heightError * config.verticalSpeed,-config.verticalSpeed,config.verticalSpeed)

        -- Target velocity
        local targetVelocity = Vector3.new(horizontal.X, y, horizontal.Z)

        -- Smooth velocity
        currentVelocity = Smooth(currentVelocity,targetVelocity, math.clamp(dt*6,0,1))
        hrp.AssemblyLinearVelocity = currentVelocity
    end

    hrp.AssemblyLinearVelocity = Vector3.zero
    moving = false
    if flyButton then flyButton.Text = "Fly to Steal" end
end

-- ================== Draggable Helper ==================
local function MakeDraggable(frame)
    local dragging = false
    local dragInput
    local dragStart
    local startPos

    local function update(input)
        local delta = input.Position - dragStart
        frame.Position = UDim2.new(
            startPos.X.Scale,
            startPos.X.Offset + delta.X,
            startPos.Y.Scale,
            startPos.Y.Offset + delta.Y
        )
    end

    frame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            dragStart = input.Position
            startPos = frame.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false
                end
            end)
        end
    end)

    frame.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement then
            dragInput = input
        end
    end)

    RunService.RenderStepped:Connect(function()
        if dragging and dragInput then
            update(dragInput)
        end
    end)
end

-- ================== Main GUI ==================
local function CreateMainGUI()
    gui = Instance.new("ScreenGui")
    gui.Name = "ARBIX_HUB_GUI"
    gui.ResetOnSpawn = false
    gui.Parent = player:WaitForChild("PlayerGui")

    local frame = Instance.new("Frame")
