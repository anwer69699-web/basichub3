-- FR Mini V2 - تصليح الأزرار والواجهة

local P = game:GetService("Players").LocalPlayer
local R = game:GetService("RunService")
local S = game:GetService("StarterGui")
local T = game:GetService("TweenService")

-- حذف القديم
for _, v in pairs(P:WaitForChild("PlayerGui"):GetChildren()) do
    if v.Name:match("FRMini") then v:Destroy() end
end
if _G.FRMiniLoop then _G.FRMiniLoop:Disconnect() _G.FRMiniLoop = nil end
if _G.FRStealLoop then _G.FRStealLoop:Disconnect() _G.FRStealLoop = nil end

-- إعدادات
local SPEED = 40
local STEAL_SPEED = 20
local DESYNC_DELAY = 0.25
local UPDATE_DIST = 20

-- متغيرات (مطفية افتراضياً)
local DesyncEnabled = false
local StealEnabled = false
local FakePos = nil
local LastUpdate = 0
local LastSend = 0

-- إشعار
local function N(m)
    pcall(function() S:SetCore("SendNotification", {Title="FR",Text=m,Duration=2}) end)
end

-- Insta Steal
local function DoSteal()
    pcall(function()
        local plots = workspace:FindFirstChild("Plots")
        if not plots then return end
        for _, plot in pairs(plots:GetChildren()) do
            local pods = plot:FindFirstChild("AnimalPodiums")
            if pods then
                for _, pod in pairs(pods:GetChildren()) do
                    local base = pod:FindFirstChild("Base")
                    local sp = base and base:FindFirstChild("Spawn")
                    local att = sp and sp:FindFirstChild("PromptAttachment")
                    if att then
                        for _, pr in pairs(att:GetChildren()) do
                            if pr:IsA("ProximityPrompt") then
                                pr.HoldDuration = 0.08
                            end
                        end
                    end
                end
            end
        end
    end)
end

-- Desync + Speed Loop
local function MainLoop()
    _G.FRMiniLoop = R.Heartbeat:Connect(function()
        if not DesyncEnabled then return end
        
        local c = P.Character
        if not c then return end
        local hrp = c:FindFirstChild("HumanoidRootPart")
        local hum = c:FindFirstChildOfClass("Humanoid")
        if not hrp or not hum then return end
        
        local realPos = hrp.Position
        local speed = StealEnabled and STEAL_SPEED or SPEED
        
        -- DESYNC
        if not FakePos then FakePos = realPos end
        
        local dist = (realPos - FakePos).Magnitude
        local now = tick()
        
        if now - LastUpdate >= DESYNC_DELAY then
            LastUpdate = now
            
            if dist > UPDATE_DIST then
                local dir = (realPos - FakePos).Unit
                FakePos = FakePos + (dir * 8)
                
                if (realPos - FakePos).Magnitude < UPDATE_DIST - 5 then
                    FakePos = realPos - (dir * (UPDATE_DIST - 5))
                end
            end
            
            if now - LastSend >= 0.15 then
                LastSend = now
                local cf = CFrame.new(FakePos)
                if typeof(rnet) == "table" then
                    if rnet.sendposition then pcall(function() rnet.sendposition(FakePos) end) end
                    if rnet.sendphysics then pcall(function() rnet.sendphysics(cf) end) end
                end
                if typeof(delta) == "table" then
                    if delta.sendposition then pcall(function() delta.sendposition(FakePos) end) end
                    if delta.sendphysics then pcall(function() delta.sendphysics(cf) end) end
                end
            end
        end
        
        -- SPEED
        hum.WalkSpeed = 28
        
        if speed > 28 and hum.MoveDirection.Magnitude > 0.1 then
            local vel = hrp.AssemblyLinearVelocity
            local target = hum.MoveDirection * speed
            hrp.AssemblyLinearVelocity = Vector3.new(
                vel.X + (target.X - vel.X) * 0.12,
                vel.Y,
                vel.Z + (target.Z - vel.Z) * 0.12
            )
        end
    end)
end

-- Steal Loop منفصل
local function StealLoop()
    _G.FRStealLoop = R.Heartbeat:Connect(function()
        if not StealEnabled then return end
        DoSteal()
    end)
end

-- === الواجهة ===
